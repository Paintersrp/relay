#!/usr/bin/env bash
# pre-commit: run fast validation evidence before commit (advisory)
# Install: make hooks-setup  OR  git config core.hooksPath .githooks
set -u

RELAY_VALIDATE_TIER=fast bash scripts/validate.sh
EXIT_CODE=$?

# Stage fast validation artifacts when present. This is allowed before commit
# and preserves failed evidence for auditor review when validation fails.
git add handoffs/validation/latest.validation-report.fast.json \
        handoffs/validation/latest.validation-summary.fast.md 2>/dev/null || true

if [ $EXIT_CODE -ne 0 ]; then
  echo "[pre-commit] fast validation evidence: FAILED (exit $EXIT_CODE)" >&2
  echo "[pre-commit] Review handoffs/validation/latest.validation-report.fast.json for details." >&2
  echo "[pre-commit] This hook is advisory. Commit will continue; failed evidence should guide audit/revision." >&2
  exit 0
fi

echo "[pre-commit] fast validation evidence: passed"
exit 0
