{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plan of Passes v1.0",
  "description": "Structural schema for the canonical Plan of Passes artifact.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {},
    "feature_slug": { "$ref": "#/$defs/feature_slug" },
    "goal": { "$ref": "#/$defs/single_line_prose" },
    "context": { "$ref": "#/$defs/multiline_prose" },
    "scope": { "$ref": "#/$defs/scope" },
    "repo_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/repository_target" }
    },
    "passes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pass" }
    },
    "completion_criteria": { "$ref": "#/$defs/criteria_array" }
  },
  "required": [
    "feature_slug",
    "goal",
    "context",
    "scope",
    "repo_targets",
    "passes",
    "completion_criteria"
  ],
  "$defs": {
    "feature_slug": {
      "type": "string",
      "pattern": "^(?!.*[\\r\\n])[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "single_line_prose": {
      "type": "string",
      "pattern": "^(?!.*[\\r\\n])(?!\\s*$)[^\\r\\n]*\\S[^\\r\\n]*$"
    },
    "multiline_prose": {
      "type": "string",
      "pattern": "^[\\s\\S]*\\S[\\s\\S]*$"
    },
    "machine_string": {
      "type": "string",
      "pattern": "^(?!.*[\\r\\n])(?!\\s*$)(?!\\s)(?!.*\\s$)[^\\u0000-\\u001F\\u007F]+$"
    },
    "repository_key": { "$ref": "#/$defs/machine_string" },
    "commit_sha": {
      "type": "string",
      "pattern": "^(?!.*[\\r\\n])[0-9a-f]{40}$"
    },
    "path": {
      "type": "string",
      "pattern": "^(?!.*[\\r\\n])(?!/)(?![A-Za-z]:)(?!//)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?$)(?!.*(?:^|/)\\.\\.?/)(?!\\s)(?!.*\\s$)(?!.*[\\u0000-\\u001F\\u007F]).*\\S.*$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "in_scope": { "$ref": "#/$defs/criteria_array" },
        "out_of_scope": { "$ref": "#/$defs/criteria_array" }
      },
      "required": ["in_scope", "out_of_scope"]
    },
    "criteria_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/single_line_prose" }
    },
    "repository_target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo_target": { "$ref": "#/$defs/repository_key" },
        "branch": { "$ref": "#/$defs/machine_string" },
        "planning_base_commit": { "$ref": "#/$defs/commit_sha" }
      },
      "required": ["repo_target", "branch", "planning_base_commit"]
    },
    "pass": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "name": { "$ref": "#/$defs/single_line_prose" },
        "repo_target": { "$ref": "#/$defs/repository_key" },
        "goal": { "$ref": "#/$defs/single_line_prose" },
        "context": { "$ref": "#/$defs/multiline_prose" },
        "scope": { "$ref": "#/$defs/scope" },
        "depends_on": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "outcomes": { "$ref": "#/$defs/criteria_array" },
        "source_targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source_target" }
        },
        "validation_intent": { "$ref": "#/$defs/criteria_array" },
        "completion_criteria": { "$ref": "#/$defs/criteria_array" }
      },
      "required": [
        "number",
        "name",
        "repo_target",
        "goal",
        "context",
        "scope",
        "depends_on",
        "outcomes",
        "source_targets",
        "validation_intent",
        "completion_criteria"
      ]
    },
    "source_target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "purpose": { "$ref": "#/$defs/single_line_prose" }
      },
      "required": ["path", "purpose"]
    }
  }
}
