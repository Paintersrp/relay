package views

import "relay/internal/store"

templ ValidationPanel(checks []store.Check) {
	if len(checks) == 0 {
		return
	}
	<div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 mt-4">
		<h3 class="font-medium text-sm mb-2">Validation Results</h3>
		<div class="space-y-1">
			for _, c := range checks {
				if c.Kind == "validation" {
					<div class="flex items-center gap-2 text-xs py-1">
						if c.Status == "pass" {
							<span class="text-green-400 font-mono">{ c.Status }</span>
						} else if c.Status == "fail" {
							<span class="text-red-400 font-mono">{ c.Status }</span>
						} else if c.Status == "warn" {
							<span class="text-yellow-400 font-mono">{ c.Status }</span>
						} else {
							<span class="text-gray-400 font-mono">{ c.Status }</span>
						}
						<span class="text-gray-300">{ c.Summary }</span>
					</div>
				}
			}
		</div>
	</div>
}
