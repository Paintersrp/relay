package views

import "relay/internal/store"

templ AgentResultSummary(run *store.Run, artifacts []store.Artifact, checks []store.Check) {
	for _, c := range checks {
		if c.Kind == "agent_result" {
			<div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 mt-8">
				<h3 class="font-medium mb-3">Agent Result</h3>
				<div class="flex items-center gap-2 text-sm">
					if c.Status == "pass" {
						<span class="text-green-400 font-mono">{ c.Status }</span>
					} else if c.Status == "fail" {
						<span class="text-red-400 font-mono">{ c.Status }</span>
					} else {
						<span class="text-yellow-400 font-mono">{ c.Status }</span>
					}
					<span class="text-gray-300">{ c.Summary }</span>
				</div>
				if c.DetailsJson != "" {
					<pre class="mt-2 p-3 bg-gray-950 rounded text-xs font-mono text-gray-400 overflow-x-auto max-h-40 whitespace-pre-wrap">{ c.DetailsJson }</pre>
				}
				<div class="mt-3 flex gap-3">
					if artifactExists(artifacts, "agent_result_raw") {
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_result_raw"}
							class="text-xs text-indigo-400 hover:text-indigo-300">View raw result</a>
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_result_raw/download"}
							class="text-xs text-gray-500 hover:text-gray-300">Download raw result</a>
					}
					if artifactExists(artifacts, "agent_result_json") {
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_result_json"}
							class="text-xs text-indigo-400 hover:text-indigo-300">View parsed JSON</a>
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_result_json/download"}
							class="text-xs text-gray-500 hover:text-gray-300">Download parsed JSON</a>
					}
				</div>
			</div>
		}
	}
}
