package views

import (
	"relay/internal/repos"
	"relay/internal/store"
)

type RepoOption struct {
	Repo     store.Repo
	Branches []repos.BranchInfo
}

templ NewHandoff(repoOptions []RepoOption) {
	@Layout("New Handoff") {
		<div class="max-w-2xl">
			<h1 class="text-2xl font-bold mb-2">New Handoff</h1>
			<p class="text-gray-500 text-sm mb-8">Paste or upload a surgical implementation handoff to start a new run.</p>

			<form action="/handoffs" method="POST" enctype="multipart/form-data" class="space-y-6">
				<div x-data="{ repoMode: '' }" class="space-y-4">
					<div>
						<label class="block text-sm font-medium text-gray-400 mb-1">Repository</label>
						if len(repoOptions) == 0 {
							<p class="text-xs text-yellow-400 mb-2">
								No repositories discovered yet. Add or scan roots in Repository Settings, or use manual entry below.
							</p>
						}
						<select name="repo_id" x-model="repoMode"
							class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
							<option value="">Manual repository path</option>
							for _, ro := range repoOptions {
								<option value={ Itoa(ro.Repo.ID) }>
									{ ro.Repo.Name } - { ro.Repo.Path }
								</option>
							}
						</select>
						<div class="mt-2">
							<a href="/settings/repos" class="text-xs text-indigo-400 hover:text-indigo-300">
								Manage repository scan roots
							</a>
						</div>
					</div>

					<div x-show="repoMode === ''" class="grid grid-cols-2 gap-4">
						<div>
							<label class="block text-sm font-medium text-gray-400 mb-1">Repo Name</label>
							<input type="text" name="repo_name"
								class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"
								placeholder="relay"/>
						</div>
						<div>
							<label class="block text-sm font-medium text-gray-400 mb-1">Repo Path</label>
							<input type="text" name="repo_path"
								class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"
								placeholder="D:/Code/relay"/>
						</div>
					</div>

					for _, ro := range repoOptions {
						if len(ro.Branches) > 0 {
							<div x-show={ "repoMode === '" + Itoa(ro.Repo.ID) + "'" }>
								<label class="block text-sm font-medium text-gray-400 mb-1">Branch / Worktree</label>
								<select name="branch_name" :disabled={ "repoMode !== '" + Itoa(ro.Repo.ID) + "'" }
									class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
									for _, b := range ro.Branches {
										if b.IsCurrent {
											<option value={ b.Name } selected>{ b.Name } (current)</option>
										} else {
											<option value={ b.Name }>{ b.Name }</option>
										}
									}
								</select>
							</div>
						} else {
							<div x-show={ "repoMode === '" + Itoa(ro.Repo.ID) + "'" }>
								<label class="block text-sm font-medium text-gray-400 mb-1">Branch / Worktree</label>
								<input type="text" name="branch_name" :disabled={ "repoMode !== '" + Itoa(ro.Repo.ID) + "'" }
									class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"
									placeholder="branch-name"/>
								<p class="text-xs text-gray-500 mt-1">No local branches discovered. Enter a branch/worktree name manually.</p>
							</div>
						}
					}

					<div x-show="repoMode === ''">
						<label class="block text-sm font-medium text-gray-400 mb-1">Branch / Worktree</label>
						<input type="text" name="branch_name" :disabled="repoMode !== ''"
							class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"
							placeholder="branch-name"/>
					</div>
				</div>

				<div x-data="{ sourceMode: 'upload', fileName: '' }" class="space-y-3">
					<label class="block text-sm font-medium text-gray-400">Handoff source</label>

					<div x-show="sourceMode === 'upload'"
						@dragover.prevent
						@drop.prevent="
							const files = $event.dataTransfer.files;
							if (files && files.length) {
								const input = document.getElementById('handoff-file');
								input.files = files;
								fileName = files[0].name;
							}
						"
						class="rounded-xl border border-dashed border-gray-700 bg-gray-900/40 p-8 text-center">
						<input id="handoff-file" type="file" name="handoff_file"
							accept=".txt,.md,text/plain,text/markdown"
							class="sr-only"
							@change="fileName = $event.target.files?.[0]?.name || ''"/>
						<label for="handoff-file" class="cursor-pointer block">
							<div class="text-2xl text-gray-500 mb-2">↥</div>
							<div class="text-sm text-gray-200">Upload handoff file</div>
							<div class="text-xs text-gray-500 mt-1">Drop or choose a .txt / .md file.</div>
							<div x-show="fileName" class="text-xs text-indigo-300 mt-2" x-text="fileName"></div>
						</label>
					</div>

					<div x-show="sourceMode === 'text'" class="space-y-1">
						<label class="block text-sm font-medium text-gray-400">Text input</label>
						<textarea name="handoff_text" rows="18"
							class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-indigo-500 resize-y"
							placeholder="Paste the full implementation handoff here..."></textarea>
					</div>

					<div class="grid grid-cols-2 gap-2">
						<button type="button"
							@click="sourceMode = 'upload'"
							class="rounded-lg border border-gray-700 bg-gray-900/60 p-3 text-sm hover:border-gray-500"
							:class="sourceMode === 'upload' ? 'border-indigo-500 text-white' : 'text-gray-400'">
							Upload
						</button>
						<button type="button"
							@click="sourceMode = 'text'"
							class="rounded-lg border border-gray-700 bg-gray-900/60 p-3 text-sm hover:border-gray-500"
							:class="sourceMode === 'text' ? 'border-indigo-500 text-white' : 'text-gray-400'">
							Text input
						</button>
					</div>

					<p class="text-xs text-gray-500">
						The run title is derived from the handoff's first # heading. If both upload and text are submitted, the upload is used.
					</p>

					<noscript>
						<div class="mt-3 space-y-2">
							<p class="text-xs text-yellow-400">JavaScript is disabled. Use either file upload or pasted text below.</p>
							<textarea name="handoff_text" rows="12"
								class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm font-mono"
								placeholder="Paste the full implementation handoff here..."></textarea>
						</div>
					</noscript>
				</div>

				<details class="rounded border border-gray-800 bg-gray-900/30 p-3">
					<summary class="cursor-pointer text-sm text-gray-400">Optional model override</summary>
					<div x-data="{ selectedModelOption: '' }" class="mt-3 space-y-2">
						<select name="selected_model_option" x-model="selectedModelOption"
							class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
							<option value="">Auto from handoff, fallback DeepSeek V4 Flash</option>
							<option value="deepseek-v4-flash">DeepSeek V4 Flash</option>
							<option value="deepseek-v4-pro">DeepSeek V4 Pro</option>
							<option value="deepseek-v4-pro-max">DeepSeek V4 Pro Max</option>
							<option value="qwen-3.7-max">Qwen3.7 Max</option>
							<option value="kimi-k2.6">Kimi K2.6</option>
							<option value="gpt-5.5-thinking">GPT-5.5 Thinking</option>
							<option value="custom">Custom</option>
						</select>
						<p class="text-xs text-gray-500">
							Relay parses the execution model from the handoff. Override only when you intentionally want a different model.
						</p>
						<div x-show="selectedModelOption === 'custom'">
							<label class="block text-sm font-medium text-gray-400 mb-1">Custom model</label>
							<input type="text" name="selected_model_custom"
								class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"
								placeholder="provider/model-id"/>
						</div>
					</div>
				</details>

				<div class="flex gap-3">
					<button type="submit"
						class="inline-flex items-center px-4 py-2 rounded bg-indigo-600 hover:bg-indigo-500 text-sm font-medium transition-colors">
						Create Run
					</button>
					<a href="/"
						class="inline-flex items-center px-4 py-2 rounded border border-gray-700 hover:border-gray-600 text-sm transition-colors">
						Cancel
					</a>
				</div>
			</form>
		</div>
	}
}
