templ StatusIcon(state string, className string) {
	@Icon(statusIconName(state), statusIconClass(state, className))
}

templ StageIcon(step string, className string) {
	@Icon(stageIconName(step), className)
}

templ ActionIcon(action string, className string) {
	@Icon(actionIconName(action), className)
}

templ ArtifactIcon(kind string, className string) {
	@Icon(artifactIconName(kind), className)
}

templ LiveUpdateIcon(state string, className string) {
	@Icon(liveUpdateIconName(state), liveUpdateIconClass(state, className))
}

templ LiveUpdateIconSet(className string) {
	<span data-relay-live-updates-state-icon="connecting" class="inline-flex items-center justify-center">
		@LiveUpdateIcon("connecting", className)
	</span>
	<span data-relay-live-updates-state-icon="connected" hidden class="inline-flex items-center justify-center">
		@LiveUpdateIcon("connected", className)
	</span>
	<span data-relay-live-updates-state-icon="reconnecting" hidden class="inline-flex items-center justify-center">
		@LiveUpdateIcon("reconnecting", className)
	</span>
	<span data-relay-live-updates-state-icon="disconnected" hidden class="inline-flex items-center justify-center">
		@LiveUpdateIcon("disconnected", className)
	</span>
}
