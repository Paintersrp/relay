package views

func iconClassName(className string) string {
	if className == "" {
		return "relay-icon"
	}
	return "relay-icon " + className
}

func statusIconName(state string) string {
	switch state {
	case "done", "passed", "pass", "completed", "accepted", "pushed":
		return "check-circle"
	case "committed_local":
		return "git-commit"
	case "ready_to_commit":
		return "circle"
	case "commit_failed", "push_failed":
		return "x-circle"
	case "blocked_validation", "blocked_audit_not_accepted", "blocked_no_diff_inspection", "blocked_mixed_changes", "blocked_no_upstream":
		return "x-circle"
	case "no_changes":
		return "circle"
	case "active", "running", "connecting":
		return "loader-circle"
	case "ready":
		return "circle"
	case "blocked", "failed", "fail", "error", "stale":
		return "x-circle"
	case "warning", "warn", "timed_out":
		return "alert-triangle"
	case "pending":
		return "circle"
	case "stale_output", "stale_timeout":
		return "clock"
	case "disconnected":
		return "wifi-off"
	default:
		return "circle"
	}
}

func statusIconClass(state string, className string) string {
	if className == "" {
		className = ""
	}
	if state == "active" || state == "running" || state == "connecting" {
		if className == "" {
			return "animate-spin"
		}
		return className + " animate-spin"
	}
	return className
}

func stageIconName(step string) string {
	switch step {
	case "intake":
		return "file-input"
	case "prompt":
		return "scroll-text"
	case "packet":
		return "package"
	case "handoff":
		return "terminal"
	case "run":
		return "bot"
	case "validation":
		return "clipboard-check"
	case "audit":
		return "file-search"
	case "commit":
		return "git-commit"
	default:
		return "circle"
	}
}

func actionIconName(action string) string {
	switch action {
	case "play", "run-validation", "run", "start-opencode-go":
		return "play"
	case "rotate-ccw", "retry", "re-run", "refresh":
		return "rotate-ccw"
	case "copy":
		return "copy"
	case "external-link", "view":
		return "external-link"
	case "download":
		return "download"
	case "file-input":
		return "file-input"
	case "scroll-text":
		return "scroll-text"
	case "package":
		return "package"
	case "terminal":
		return "terminal"
	case "bot":
		return "bot"
	case "clipboard-check":
		return "clipboard-check"
	case "file-search":
		return "file-search"
	case "file-text":
		return "file-text"
	case "file-diff":
		return "file-diff"
	case "braces":
		return "braces"
	case "git-branch":
		return "git-branch"
	case "git-commit":
		return "git-commit"
	case "upload-cloud", "push", "push-to-upstream":
		return "upload-cloud"
	case "settings":
		return "settings"
	case "database":
		return "database"
	case "folder-git":
		return "folder-git"
	case "life-buoy":
		return "life-buoy"
	case "badge-check":
		return "badge-check"
	case "message-square":
		return "message-square"
	case "wifi":
		return "wifi"
	case "wifi-off":
		return "wifi-off"
	case "chevron-left":
		return "chevron-left"
	case "chevron-right":
		return "chevron-right"
	default:
		return action
	}
}

func artifactIconName(kind string) string {
	switch kind {
	case "agent_prompt", "validation_progress_json", "commit_message_text":
		return "scroll-text"
	case "intake_remediation_handoff", "audit_handoff":
		return "file-text"
	case "opencode_handoff_packet":
		return "package"
	case "opencode_cli_check_json", "opencode_dry_run_json", "agent_result_json", "validation_run_json", "git_commit_state_json", "git_push_dry_run_json", "commit_suggestion_json", "opencode_lifecycle_diagnostic_json":
		return "braces"
	case "opencode_stdout", "opencode_stderr", "opencode_combined_log", "agent_result_raw", "validation_stdout", "validation_stderr":
		return "terminal"
	case "git_status_text", "git_diff_name_status", "git_diff_stat", "git_diff_patch":
		return "file-diff"
	case "git_commit_result_json":
		return "git-commit"
	case "git_push_result_json":
		return "upload-cloud"
	default:
		return "file-text"
	}
}

func liveUpdateIconName(state string) string {
	switch state {
	case "connected":
		return "wifi"
	case "connecting":
		return "loader-circle"
	case "reconnecting":
		return "loader-circle"
	case "disconnected":
		return "wifi-off"
	default:
		return "wifi"
	}
}

func liveUpdateIconClass(state string, className string) string {
	switch state {
	case "connecting", "reconnecting":
		if className == "" {
			return "animate-spin"
		}
		return className + " animate-spin"
	default:
		return className
	}
}

func nextActionIconName(action WorkbenchNextActionView) string {
	switch action.Kind {
	case "generate_fix_handoff":
		return "file-text"
	case "generate_agent_prompt":
		return "scroll-text"
	case "generate_agent_packet":
		return "package"
	case "check_opencode_cli":
		return "terminal"
	case "preview_opencode_command":
		return "play"
	case "start_opencode":
		return "bot"
	case "finalize_opencode_without_result":
		return "file-search"
	case "monitor_agent_run":
		return "bot"
	case "review_agent_result":
		return "clipboard-check"
	case "run_validation":
		return "play"
	case "review_validation_output":
		return "file-search"
	case "ready_for_audit":
		return "file-search"
	case "committed_local":
		return "git-commit"
	case "pushed":
		return "upload-cloud"
	default:
		return actionIconName(action.Kind)
	}
}

templ iconBase(className string) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
		focusable="false"
		class={ iconClassName(className) }>
		{ children... }
	</svg>
}

