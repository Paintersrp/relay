package views

import "relay/internal/store"

templ ArtifactList(artifacts []store.Artifact, runID int64) {
	<div class="relay-card p-4">
		<h3 class="font-medium mb-3 inline-flex items-center gap-2">
			@ActionIcon("file-text", "relay-icon-sm")
			<span>Artifacts</span>
		</h3>
		if len(artifacts) == 0 {
			<p class="text-xs text-gray-600">No artifacts yet.</p>
		} else {
			<ul class="space-y-2">
				for _, a := range artifacts {
					<li class="flex flex-col sm:flex-row sm:items-center sm:justify-between text-xs py-2 border-b border-gray-800/50 last:border-0 gap-1 sm:gap-0">
						<div class="min-w-0">
							<span class="text-gray-300 font-medium break-all">{ a.Kind }</span>
							<span class="text-gray-600 sm:ml-2 block sm:inline">{ a.CreatedAt }</span>
						</div>
						<div class="relay-action-row shrink-0">
							@ArtifactPreviewLink(runID, a.Kind, "text-indigo-400 hover:text-indigo-300 min-h-[32px] inline-flex items-center") {
								View
							}
							<a href={"/runs/" + Itoa(runID) + "/artifacts/" + a.Kind + "/download"}
								class="text-gray-500 hover:text-gray-300 min-h-[32px] inline-flex items-center gap-1.5">
								@ActionIcon("download", "relay-icon-sm")
								<span>Download</span>
							</a>
						</div>
					</li>
				}
			</ul>
		}
	</div>
}
