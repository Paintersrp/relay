package views

import (
	"fmt"
	"relay/internal/pipeline"
	"relay/internal/store"
	"time"
)

type pipelineStage struct {
	Key        string
	Number     string
	Label      string
	ShortLabel string
	Helper     string
}

func pipelineStages() []pipelineStage {
	return []pipelineStage{
		{Key: "intake", Number: "1", Label: "Intake", ShortLabel: "Intake", Helper: "Validate handoff structure"},
		{Key: "prompt", Number: "2", Label: "Prompt", ShortLabel: "Prompt", Helper: "Generate compact repo-agent prompt"},
		{Key: "packet", Number: "3", Label: "Packet", ShortLabel: "Packet", Helper: "Bundle execution handoff"},
		{Key: "handoff", Number: "4", Label: "OpenCode", ShortLabel: "OpenCode", Helper: "Check CLI and command preview"},
		{Key: "run", Number: "5", Label: "Agent Run", ShortLabel: "Run", Helper: "Execute or review agent output"},
		{Key: "validation", Number: "6", Label: "Validation", ShortLabel: "Validation", Helper: "Run project validation commands"},
		{Key: "audit", Number: "7", Label: "Diff / Audit", ShortLabel: "Audit", Helper: "Inspect diff and generate audit handoff"},
		{Key: "commit", Number: "8", Label: "Git Commit / Push", ShortLabel: "Commit", Helper: "Review state, commit, and push changes"},
	}
}

func previousPipelineStage(activeStep string) (pipelineStage, bool) {
	steps := pipelineStages()
	for i, s := range steps {
		if s.Key == activeStep && i > 0 {
			return steps[i-1], true
		}
	}
	return pipelineStage{}, false
}

func nextPipelineStage(activeStep string) (pipelineStage, bool) {
	steps := pipelineStages()
	for i, s := range steps {
		if s.Key == activeStep && i < len(steps)-1 {
			return steps[i+1], true
		}
	}
	return pipelineStage{}, false
}

func pipelineStageState(step string, activeStep string, previews RunPreviews, artifacts []store.Artifact, checks []store.Check, intakeReview *pipeline.IntakeReview) string {
	switch step {
	case "intake":
		if hasCheckKind(checks, "validation") {
			return "done"
		}
		if activeStep == "intake" {
			return "active"
		}
		if artifactExists(artifacts, "original_handoff") {
			return "ready"
		}
		return "pending"
	case "prompt":
		if artifactExists(artifacts, "agent_prompt") {
			return "done"
		}
		if intakeReview != nil && len(intakeReview.Blockers) > 0 {
			return "blocked"
		}
		if intakeReview != nil {
			return "ready"
		}
		return "pending"
	case "packet":
		if artifactExists(artifacts, "opencode_handoff_packet") {
			return "done"
		}
		if artifactExists(artifacts, "agent_prompt") {
			return "ready"
		}
		return "pending"
	case "handoff":
		if artifactExists(artifacts, "opencode_dry_run_json") && artifactExists(artifacts, "opencode_cli_check_json") {
			return "done"
		}
		if artifactExists(artifacts, "opencode_handoff_packet") {
			if previews.OpenCodeAdapterError != "" || previews.HandoffPreflightStatus == "blocked" {
				return "blocked"
			}
			return "ready"
		}
		return "pending"
	case "run":
		if previews.HasOpenCodeStaleRunning {
			return "blocked"
		}
		if previews.HasOpenCodeRunning {
			return "running"
		}
		if artifactExists(artifacts, "agent_result_raw") {
			return "done"
		}
		if previews.OpenCodeExecutionStatus == "failed" || previews.OpenCodeExecutionStatus == "completed" {
			return "blocked"
		}
		if artifactExists(artifacts, "opencode_handoff_packet") {
			if previews.OpenCodeAdapterError != "" || previews.HandoffPreflightStatus == "blocked" {
				return "pending"
			}
			return "ready"
		}
		return "pending"
	case "validation":
		if previews.ValidationProgressRunning {
			return "running"
		}
		if hasCheckStatus(checks, "validation_run", "pass") {
			return "done"
		}
		if hasCheckStatus(checks, "validation_run", "fail") {
			if previews.ValidationFailedAccepted {
				return "done"
			}
			return "blocked"
		}
		if artifactExists(artifacts, "agent_result_raw") && previews.HasValidationCommands {
			return "ready"
		}
		return "pending"
	case "audit":
		if artifactExists(artifacts, "audit_handoff") {
			return "done"
		}
		if hasCheckStatus(checks, "validation_run", "pass") || previews.ValidationFailedAccepted {
			return "ready"
		}
		return "pending"
	case "commit":
		switch previews.CommitState {
		case "pushed", "committed_local", "no_changes":
			return "done"
		case "push_failed", "commit_failed", "blocked_validation", "blocked_audit_not_accepted", "blocked_no_diff_inspection", "blocked_mixed_changes", "blocked_no_upstream", "unknown":
			return "blocked"
		case "ready_to_commit":
			return "ready"
		}
		if previews.HasPushResult && previews.PushResultSuccess {
			return "done"
		}
		if previews.HasCommitResult && previews.CommitResultSuccess {
			return "done"
		}
		if artifactExists(artifacts, "commit_message_text") || previews.CommitSuggestionSelected != "" {
			return "ready"
		}
		if artifactExists(artifacts, "audit_handoff") {
			return "ready"
		}
		return "pending"
	}
	return "pending"
}

func pipelineStageStateLabel(state string) string {
	switch state {
	case "active":
		return "active"
	case "done":
		return "done"
	case "ready":
		return "ready"
	case "running":
		return "running"
	case "blocked":
		return "blocked"
	case "pending":
		return "pending"
	default:
		return state
	}
}

func pipelineStageLinkClass(step string, activeStep string, state string) string {
	if activeStep == step {
		return "relay-stage-link relay-stage-link-active"
	}
	switch state {
	case "done":
		return "relay-stage-link relay-stage-link-done"
	case "ready":
		return "relay-stage-link relay-stage-link-ready"
	case "running":
		return "relay-stage-link relay-stage-link-running"
	case "blocked":
		return "relay-stage-link relay-stage-link-blocked"
	case "pending":
		return "relay-stage-link relay-stage-link-pending"
	default:
		return "relay-stage-link"
	}
}

templ SelectedStagePanel(run *store.Run, repo *store.Repo, artifacts []store.Artifact, checks []store.Check, previews RunPreviews, intakeReview *pipeline.IntakeReview, activeStep string) {
	<div class="relay-stage-panel-card">
		@SelectedStageHeader(activeStep, previews)
		@SelectedStageBody(run, repo, artifacts, checks, previews, intakeReview, activeStep)
		@StepFlowFooter(run.ID, activeStep)
	</div>
}

templ PipelineStageRail(runID int64, previews RunPreviews, artifacts []store.Artifact, checks []store.Check, intakeReview *pipeline.IntakeReview, activeStep string) {
	<nav class="space-y-1" aria-label="Pipeline stages">
		for _, step := range pipelineStages() {
			{{ state := pipelineStageState(step.Key, activeStep, previews, artifacts, checks, intakeReview) }}
			<a href={"/runs/" + Itoa(runID) + "?step=" + step.Key}
				hx-get={"/runs/" + Itoa(runID) + "?step=" + step.Key}
				hx-target="#run-workbench-shell"
				hx-select="#run-workbench-shell"
				hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms"
				hx-push-url="true"
				hx-indicator="#run-workbench-loading"
				data-relay-workbench-link="true"
				class={pipelineStageLinkClass(step.Key, activeStep, state)}>
				<div class="flex items-center gap-2">
					@StageIcon(step.Key, "relay-icon-sm")
					<span class="font-medium">{ step.ShortLabel }</span>
					<span class="text-xs ml-auto">{ pipelineStageStateLabel(state) }</span>
				</div>
				<div class="text-xs text-gray-500 mt-0.5">{ step.Helper }</div>
			</a>
		}
	</nav>
}

templ PipelineStageStrip(runID int64, previews RunPreviews, artifacts []store.Artifact, checks []store.Check, intakeReview *pipeline.IntakeReview, activeStep string) {
	<div class="relay-stage-strip" data-pipeline-stage-strip>
		<nav class="relay-stage-strip-row" aria-label="Pipeline stages">
			for _, step := range pipelineStages() {
				{{ state := pipelineStageState(step.Key, activeStep, previews, artifacts, checks, intakeReview) }}
				<a href={"/runs/" + Itoa(runID) + "?step=" + step.Key}
					hx-get={"/runs/" + Itoa(runID) + "?step=" + step.Key}
					hx-target="#run-workbench-shell"
					hx-select="#run-workbench-shell"
					hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms"
					hx-push-url="true"
					hx-indicator="#run-workbench-loading"
					data-relay-workbench-link="true"
					class={pipelineStageLinkClass(step.Key, activeStep, state) + " shrink-0 min-w-[8.5rem] max-w-[12rem] snap-start"}>
					@StageIcon(step.Key, "relay-icon-sm")
					<span class="font-medium whitespace-nowrap">{ step.ShortLabel }</span>
					<span class="text-xs">{ pipelineStageStateLabel(state) }</span>
				</a>
			}
		</nav>
	</div>
}

templ SelectedStageBody(run *store.Run, repo *store.Repo, artifacts []store.Artifact, checks []store.Check, previews RunPreviews, intakeReview *pipeline.IntakeReview, activeStep string) {
	switch activeStep {
	case "intake":
		@IntakeStepPanel(run, repo, artifacts, checks, intakeReview, previews)
	case "prompt":
		@AgentPromptStepPanel(run, artifacts, checks, previews, intakeReview)
	case "packet":
		@AgentPacketStepPanel(run, artifacts, previews)
	case "handoff":
		@OpenCodeGoHandoffStepPanel(run, artifacts, checks, previews)
	case "run":
		@AgentRunMonitorStepPanel(run, artifacts, checks, previews)
	case "validation":
		@RelayValidationStepPanel(run, artifacts, checks, previews)
	case "audit":
		@DiffAuditStepPanel(previews, run.ID)
	case "commit":
		@GitCommitStepPanel(run, artifacts, previews)
	default:
		@IntakeStepPanel(run, repo, artifacts, checks, intakeReview, previews)
	}
}

templ SelectedStageHeader(activeStep string, previews RunPreviews) {
	<div class="relay-card-header border-b border-gray-800">
		<div class="min-w-0">
			<h3 class="font-medium text-base sm:text-lg inline-flex items-center gap-2" tabindex="-1" data-run-stage-heading>
				@StageIcon(activeStep, "relay-icon")
				{ stepDisplayLabel(activeStep) }
			</h3>
			<p class="text-xs sm:text-sm text-gray-500 mt-0.5">
				{ stepDescription(activeStep) }
			</p>
		</div>
	</div>
}

templ StepFlowFooter(runID int64, activeStep string) {
	<footer class="relay-stage-footer">
		if prev, ok := previousPipelineStage(activeStep); ok {
			<a href={"/runs/" + Itoa(runID) + "?step=" + prev.Key}
				hx-get={"/runs/" + Itoa(runID) + "?step=" + prev.Key}
				hx-target="#run-workbench-shell"
				hx-select="#run-workbench-shell"
				hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms"
				hx-push-url="true"
				hx-indicator="#run-workbench-loading"
				data-relay-workbench-link="true"
				class="text-sm text-gray-400 hover:text-gray-300 min-h-[36px] inline-flex items-center gap-1.5">
				@ActionIcon("chevron-left", "relay-icon-sm")
				<span>Back: { prev.Label }</span>
			</a>
		} else {
			<span></span>
		}
		if next, ok := nextPipelineStage(activeStep); ok {
			<a href={"/runs/" + Itoa(runID) + "?step=" + next.Key}
				hx-get={"/runs/" + Itoa(runID) + "?step=" + next.Key}
				hx-target="#run-workbench-shell"
				hx-select="#run-workbench-shell"
				hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms"
				hx-push-url="true"
				hx-indicator="#run-workbench-loading"
				data-relay-workbench-link="true"
				class="text-sm text-gray-400 hover:text-gray-300 min-h-[36px] inline-flex items-center gap-1.5">
				<span>Next: { next.Label }</span>
				@ActionIcon("chevron-right", "relay-icon-sm")
			</a>
		} else {
			<span></span>
		}
	</footer>
}

templ WorkbenchStepLink(runID int64, step string, iconName string, className string) {
	<a href={"/runs/" + Itoa(runID) + "?step=" + step}
		hx-get={"/runs/" + Itoa(runID) + "?step=" + step}
		hx-target="#run-workbench-shell"
		hx-select="#run-workbench-shell"
		hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms"
		hx-push-url="true"
		hx-indicator="#run-workbench-loading"
		data-relay-workbench-link="true"
		class={className + " inline-flex items-center gap-1.5"}>
		if iconName != "" {
			@ActionIcon(iconName, "relay-icon-sm")
		}
		{ children... }
	</a>
}

templ WorkbenchActionForm(runID int64, action string, className string) {
	<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
		hx-post={"/runs/" + Itoa(runID) + "/actions"}
		hx-target="#run-workbench-shell"
		hx-select="#run-workbench-shell"
		hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms"
		hx-indicator="#run-workbench-loading"
		data-relay-workbench-action="true"
		class={className}>
		<input type="hidden" name="action" value={action}/>
		{ children... }
	</form>
}

templ IntakeStepPanel(run *store.Run, repo *store.Repo, artifacts []store.Artifact, checks []store.Check, intakeReview *pipeline.IntakeReview, previews RunPreviews) {
	<div class="relay-card">
		<div class="relay-card-header">
			<div class="flex flex-wrap items-center gap-2 sm:gap-3">
				@intakeStatusChip(checks)
				<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
					hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
					hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
					class="inline">
					<input type="hidden" name="action" value="validate-handoff"/>
					<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
						@ActionIcon("clipboard-check", "relay-icon-sm")
						if hasCheckKind(checks, "validation") {
							Re-run Intake Review
						} else {
							Run Intake Review
						}
					</button>
				</form>
			</div>
		</div>

		<div class="relay-stage-evidence-list">
			if intakeReview != nil {
				if len(intakeReview.Blockers) > 0 {
					@StageFailurePanel("Blocking issues found", "Resolve these before generating the Agent Prompt.") {
						<ul class="mt-2 list-disc pl-5 text-xs sm:text-sm text-red-200 space-y-1">
							for _, blocker := range intakeReview.Blockers {
								<li>{ blocker }</li>
							}
						</ul>
					}
				}

				if len(intakeReview.Warnings) > 0 {
					@StageEvidenceRow("warning", "Warnings", "You can continue, but Relay Validation may need setup later.", "") {
						<ul class="mt-1 list-disc pl-5 text-xs text-yellow-100 space-y-0.5">
							for _, warning := range intakeReview.Warnings {
								<li>{ warning }</li>
							}
						</ul>
					}
				}
			}

			if intakeReview != nil {
				@StageEvidenceRow("passed", "Intake Review", "", "") {
					@IntakeReviewPanel(run, repo, intakeReview)
				}
			}

			if intakeReview != nil && (len(intakeReview.Blockers) > 0 || len(intakeReview.Warnings) > 0) {
				if previews.HasIntakeRemediationHandoff {
					@StageEvidenceRow("ready", "Fix handoff generated", "", "") {
						@ArtifactPreviewLink(run.ID, "intake_remediation_handoff", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View fix handoff
						}
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/intake_remediation_handoff/download"}
							class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download fix handoff</a>
						if previews.IntakeRemediationHandoff != "" {
							<details class="mt-2">
								<summary class="cursor-pointer text-xs text-gray-500 hover:text-gray-300 list-none min-h-[36px] inline-flex items-center">
									Preview fix handoff
								</summary>
								<div class="mt-2 relay-card p-3 max-h-60 overflow-auto min-w-0">
									<pre class="text-xs font-mono text-gray-300 whitespace-pre-wrap break-words">{ previews.IntakeRemediationHandoff }</pre>
								</div>
							</details>
						}
					}
				} else {
					@StageEvidenceRow("warning", "Fix handoff needed", "Generate a fix handoff to address issues.", "") {
						<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
							hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
							hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
							class="inline">
							<input type="hidden" name="action" value="generate-intake-remediation-handoff"/>
							<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
								@ActionIcon("file-text", "relay-icon-sm")
								Generate Fix Handoff
							</button>
						</form>
					}
				}
			}

			if intakeReview != nil && len(intakeReview.Blockers) > 0 {
				<div class="px-4 text-xs text-red-400 pb-3">
					Resolve the blocking issues above before generating the Agent Prompt.
				</div>
			} else if intakeReview != nil && len(intakeReview.Warnings) > 0 {
				<div class="px-4 text-xs text-yellow-300 pb-3">
					Warnings do not block Agent Prompt generation. You can continue, but Relay Validation may need setup later.
				</div>
			} else if hasCheckKind(checks, "validation") && hasCheckStatus(checks, "validation", "pass") {
				<div class="px-4 text-xs text-green-400 pb-3">
					Intake Review passed. Proceed to Agent Prompt step.
				</div>
			}

			@StageEvidenceRow("not-available", "Original handoff artifact", "", "") {
				<div class="relay-stage-output-preview">
					<div class="max-h-60 overflow-auto min-w-0">
						<pre id="original-handoff-preview" class="text-xs font-mono text-gray-300 whitespace-pre-wrap break-words p-3">{ previews.OriginalHandoff }</pre>
					</div>
				</div>
			}

			@StageEvidenceRow("not-available", "Replace original handoff", "Use this when Intake Review produced a fix handoff or when validation commands need to be added. Replacing clears downstream artifacts.", "") {
				<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
					hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
					hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
					class="space-y-3 w-full">
					<input type="hidden" name="action" value="replace-original-handoff"/>
					<textarea name="handoff_text" rows="6"
						class="w-full text-xs font-mono bg-gray-950 border border-gray-800 rounded-lg p-2 text-gray-300 min-w-0 resize-y"
						placeholder="Paste the corrected handoff text here...">{ previews.OriginalHandoff }</textarea>
					<button type="submit" class="btn-primary text-xs sm:text-sm" data-stage-primary-action>
						Replace Handoff and Re-run Intake Review
					</button>
				</form>
			}
		</div>
	</div>
}

templ AgentPromptStepPanel(run *store.Run, artifacts []store.Artifact, checks []store.Check, previews RunPreviews, intakeReview *pipeline.IntakeReview) {
	<div class="relay-card">
		<div class="relay-card-header">
			<div class="flex flex-wrap items-center gap-2 sm:gap-3 w-full">
				@agentPromptStatusChip(artifactExists(artifacts, "agent_prompt"), checks)
				<div class="flex flex-wrap items-center gap-2 sm:gap-3">
					if artifactExists(artifacts, "agent_prompt") {
						@WorkbenchStepLink(run.ID, "packet", "package", "btn-primary text-xs sm:text-sm gap-1.5") {
							Continue to Packet
						}
						<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
							hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
							hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
							class="inline">
							<input type="hidden" name="action" value="prepare-prompt"/>
							<button type="submit" class="btn-secondary text-xs sm:text-sm gap-1.5" data-stage-secondary-action>
								@ActionIcon("scroll-text", "relay-icon-sm")
								Regenerate Agent Prompt
							</button>
						</form>
						@ArtifactPreviewLink(run.ID, "agent_prompt", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View Full Prompt
						}
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_prompt/download"}
							class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download Prompt</a>
					} else {
						<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
							hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
							hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
							class="inline">
							<input type="hidden" name="action" value="prepare-prompt"/>
							<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
								@ActionIcon("scroll-text", "relay-icon-sm")
								Generate Agent Prompt
							</button>
						</form>
					}
				</div>
			</div>
		</div>

		<div class="p-4 space-y-4">
			if artifactExists(artifacts, "agent_prompt") {
				<div class="grid gap-4 xl:grid-cols-2">
					<section class="relay-card">
						<div class="flex items-center justify-between border-b border-gray-800 px-4 py-3">
							<h3 class="font-medium text-sm sm:text-base">Transformation summary</h3>
						</div>
						<div class="p-4 space-y-3">
							for _, item := range promptTransformationItems(run, intakeReview, previews) {
								<div class="flex gap-3">
									<span class="mt-0.5 shrink-0 text-green-400">
										@StatusIcon("passed", "relay-icon-sm")
									</span>
									<div class="min-w-0">
										<div class="text-sm font-medium text-gray-100">{ item.Title }</div>
										<div class="text-xs text-gray-400 mt-0.5">{ item.Detail }</div>
									</div>
								</div>
							}
						</div>
					</section>

					<section class="relay-card">
						<div class="flex items-center justify-between border-b border-gray-800 px-4 py-3">
							<h3 class="font-medium text-sm sm:text-base">Model and execution</h3>
						</div>
						<div class="p-4 space-y-3">
							for _, row := range promptModelExecutionRows(run, intakeReview, previews) {
								<div class="rounded-lg border border-gray-800 bg-gray-950/40 p-3">
									<div class="text-[11px] font-medium uppercase tracking-wider text-gray-500">{ row.Label }</div>
									<div class="mt-1 text-sm text-gray-200 whitespace-pre-wrap break-words">{ row.Value }</div>
								</div>
							}
						</div>
					</section>

					<section class="relay-card xl:col-span-2">
						<div class="flex items-center justify-between border-b border-gray-800 px-4 py-3">
							<h3 class="font-medium text-sm sm:text-base">Scope preserved</h3>
						</div>
						<div class="p-4">
							if files := promptScopedFiles(intakeReview); len(files) > 0 {
								<div class="flex flex-wrap gap-2">
									for _, file := range files {
										<span class="relay-chip-gray font-mono text-[11px] sm:text-xs break-all">{ file }</span>
									}
								</div>
							} else {
								<p class="text-sm text-gray-400">No explicit scoped files were declared.</p>
							}
						</div>
					</section>

					<section class="relay-card xl:col-span-2">
						<div class="flex items-center justify-between border-b border-gray-800 px-4 py-3">
							<h3 class="font-medium text-sm sm:text-base">Prompt preview</h3>
						</div>
						<div class="p-4">
							<div class="rounded-lg border border-gray-800 bg-gray-950/40 p-4">
								<pre class="text-xs sm:text-sm leading-6 font-mono text-gray-300 whitespace-pre-wrap break-words">{ promptPreviewExcerpt(previews.AgentPrompt, 1200) }</pre>
							</div>
						</div>
					</section>
				</div>

				if len(previews.AgentPromptDiff.Lines) > 0 {
					<details class="rounded-xl border border-gray-800 bg-gray-950/40">
						<summary class="cursor-pointer list-none flex items-center justify-between gap-3 px-4 py-3 text-sm text-gray-200 min-h-[44px]">
							<span>Technical prompt diff</span>
							<span class="text-xs text-gray-500">Collapsed by default</span>
						</summary>
						<div class="border-t border-gray-800 p-4">
							<div class="max-h-96 overflow-auto min-w-0 text-xs leading-5 font-mono">
								for _, line := range previews.AgentPromptDiff.Lines {
									switch line.Kind {
									case "add":
										<div class="text-green-300 whitespace-pre-wrap break-words">+ { line.Text }</div>
									case "remove":
										<div class="text-red-300 whitespace-pre-wrap break-words">- { line.Text }</div>
									case "skip":
										<div class="text-gray-600 italic whitespace-pre-wrap break-words">{ line.Text }</div>
									default:
										<div class="text-gray-500 whitespace-pre-wrap break-words">  { line.Text }</div>
									}
								}
							</div>
							if previews.AgentPromptDiff.Truncated {
								<div class="mt-3 border-t border-gray-800 pt-3 text-xs text-yellow-300">
									Diff preview truncated. Use View Full Prompt or Download Prompt for the full artifacts.
								</div>
							}
						</div>
					</details>
				}
			} else if hasCheckStatus(checks, "validation", "block") || hasCheckStatus(checks, "validation", "fail") {
				<div class="rounded-xl border border-red-800/50 bg-red-950/20 p-4 space-y-2">
					<div class="text-sm font-medium text-red-200">Intake Review has blockers</div>
					<div class="text-sm text-red-100/80">Resolve intake blockers before generating the Agent Prompt.</div>
					<div class="flex flex-wrap gap-2">
						@WorkbenchStepLink(run.ID, "intake", "clipboard-check", "btn-secondary text-xs sm:text-sm") {
							Review Intake
						}
					</div>
				</div>
			} else {
				<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-4 space-y-3">
					<div class="text-sm font-medium text-gray-100">What Relay will generate</div>
					<ul class="space-y-2 text-sm text-gray-300">
						for _, item := range promptTransformationItems(run, intakeReview, previews) {
							<li class="flex gap-3">
								<span class="mt-0.5 shrink-0 text-gray-500">
									@StatusIcon("pending", "relay-icon-sm")
								</span>
								<div class="min-w-0">
									<div class="font-medium text-gray-100">{ item.Title }</div>
									<div class="text-xs text-gray-400 mt-0.5">{ item.Detail }</div>
								</div>
							</li>
						}
					</ul>
					<div class="text-xs text-gray-500">
						Relay will remove orchestration-only text, preserve the scoped implementation instructions, and attach the repo-agent execution contract before moving to the packet step.
					</div>
				</div>
			}
		</div>
	</div>
}

templ AgentPacketStepPanel(run *store.Run, artifacts []store.Artifact, previews RunPreviews) {
	<div class="relay-card">
		<div class="relay-card-header">
			<div class="flex flex-wrap items-center gap-2 sm:gap-3">
				@agentPacketStatusChip(artifactExists(artifacts, "opencode_handoff_packet"), artifactExists(artifacts, "agent_prompt"))
				if artifactExists(artifacts, "agent_prompt") {
					<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
						hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
						hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
						class="inline">
						<input type="hidden" name="action" value="generate-opencode-packet"/>
					<button type="submit" class="btn-secondary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
						@ActionIcon("package", "relay-icon-sm")
						if artifactExists(artifacts, "opencode_handoff_packet") {
							Regenerate Agent Packet
						} else {
								Generate Agent Packet
							}
						</button>
					</form>
				} else {
					<span class="relay-chip-gray text-xs">
						Generate Agent Prompt first
					</span>
				}
			</div>
		</div>

		<div class="relay-stage-evidence-list">
			if artifactExists(artifacts, "opencode_handoff_packet") {
				@StageEvidenceRow("ready", "Agent Packet generated", "Relay has prepared metadata for external agent tooling. Relay does not auto-run OpenCode.", "") {
					@ArtifactPreviewLink(run.ID, "opencode_handoff_packet", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
						View
					}
					<a href={"/runs/" + Itoa(run.ID) + "/artifacts/opencode_handoff_packet/download"}
						class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download</a>
				}
				if previews.OpenCodePacket != "" {
					@StageEvidenceRow("passed", "Packet preview", "Metadata only. Use Step 4 to run OpenCode.", "") {
						<div class="relay-stage-output-preview">
							<div class="max-h-80 overflow-auto min-w-0">
								<pre class="text-xs leading-5 font-mono p-3 text-gray-300 whitespace-pre-wrap break-words">{ previews.OpenCodePacket }</pre>
							</div>
						</div>
					}
				}
			} else {
				@StageEvidenceRow("pending", "Agent Packet not generated", "Generate the Agent Prompt first, then generate the Agent Packet.", "")
			}
		</div>
	</div>
}

templ OpenCodeGoHandoffStepPanel(run *store.Run, artifacts []store.Artifact, checks []store.Check, previews RunPreviews) {
	<div class="relay-card">
		<div class="relay-card-header">
			<div class="flex flex-wrap items-center gap-2">
				@handoffStatusChip(artifactExists(artifacts, "opencode_handoff_packet"))
				@handoffPreflightStatusChip(previews.HandoffPreflightStatus)
				if previews.HasOpenCodeExecution {
					@openCodeExecutionStatusChip(previews.OpenCodeExecutionStatus)
				}
			</div>
		</div>

		<div class="relay-stage-evidence-list">
				if previews.OpenCodeAdapterError != "" {
				@StageFailurePanel("OpenCode adapter blocked", previews.OpenCodeAdapterError) {
					if previews.HasOpenCodeCLICheck {
						@ArtifactPreviewLink(run.ID, "opencode_cli_check_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View CLI check
						}
					}
				}
			} else if previews.HandoffPreflightStatus == "blocked" {
				@StageFailurePanel("Handoff preflight checks blocked", "Resolve blocked checks before starting OpenCode Go.") {
					for _, c := range previews.HandoffPreflightChecks {
						if c.Status == "block" {
							<div class="text-xs text-red-200">{ c.Key }: { c.Summary }</div>
						}
					}
				}
			}

			if previews.HasOpenCodeExecution && previews.OpenCodeExecutionStatus == "failed" {
				@StageFailurePanel("OpenCode execution failed", "") {
					if previews.OpenCodeFailureHint != "" {
						<div class="text-xs sm:text-sm text-red-200 mt-1">{ previews.OpenCodeFailureHint }</div>
					} else if previews.OpenCodeExecutionError != "" {
						<div class="text-xs sm:text-sm text-red-200 mt-1">{ previews.OpenCodeExecutionError }</div>
					} else if previews.OpenCodeExecutionExitCode != "" {
						<div class="text-xs sm:text-sm text-red-200 mt-1">
							OpenCode exited with code { previews.OpenCodeExecutionExitCode }.
						</div>
					} else {
						<div class="text-xs sm:text-sm text-red-200 mt-1">OpenCode failed. Review execution metadata.</div>
					}
					<div class="relay-action-row">
						if previews.HasOpenCodeStdout {
							@ArtifactPreviewLink(run.ID, "opencode_stdout", "text-xs text-red-300 hover:text-red-200 underline min-h-[36px] inline-flex items-center") {
								stdout
							}
						}
						if previews.HasOpenCodeStderr {
							@ArtifactPreviewLink(run.ID, "opencode_stderr", "text-xs text-red-300 hover:text-red-200 underline min-h-[36px] inline-flex items-center") {
								stderr
							}
						}
						if previews.HasOpenCodeCombinedLog {
							@ArtifactPreviewLink(run.ID, "opencode_combined_log", "text-xs text-red-300 hover:text-red-200 underline min-h-[36px] inline-flex items-center") {
								combined log
							}
						}
				</div>
				if !previews.HasOpenCodeCLICheck {
						<div class="text-xs text-red-200 mt-2">
							No OpenCode CLI check found. Run <strong>Check OpenCode CLI</strong> to verify the binary and model.
						</div>
					}
				}
			}

			if len(previews.HandoffPreflightChecks) > 0 {
				@StageEvidenceRow("ready", "Handoff preflight checks", "Checks run at page load.", "") {
					<div class="space-y-1">
						for _, c := range previews.HandoffPreflightChecks {
							<div class="flex items-center justify-between text-xs sm:text-sm">
								<span class="text-gray-400 min-w-0 truncate">{ c.Key }</span>
								if c.Status == "pass" {
									<span class="text-green-400 shrink-0 ml-2">{ c.Status }</span>
								} else if c.Status == "block" {
									<span class="text-red-400 shrink-0 ml-2">{ c.Status }</span>
								} else if c.Status == "warn" {
									<span class="text-yellow-400 shrink-0 ml-2">{ c.Status }</span>
								} else {
									<span class="text-gray-500 shrink-0 ml-2">{ c.Status }</span>
								}
							</div>
						}
					</div>
				}
			}

			@StageEvidenceRow("ready", "Selected model", "", "") {
				<div class="flex flex-col gap-2">
					<span class="text-gray-200 font-mono break-all">{ run.SelectedModel }</span>
					<details class="text-sm">
						<summary class="cursor-pointer text-indigo-400 hover:text-indigo-300">Change selected model</summary>
						<div class="mt-2 space-y-2">
							@WorkbenchActionForm(run.ID, "update-selected-model", "") {
								<select name="selected_model_option" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-200">
									<option value="">Auto from handoff / current</option>
									<option value="deepseek-v4-flash">DeepSeek V4 Flash</option>
									<option value="deepseek-v4-pro">DeepSeek V4 Pro</option>
									<option value="deepseek-v4-pro-max">DeepSeek V4 Pro Max</option>
									<option value="qwen-3.7-max">Qwen3.7 Max</option>
									<option value="kimi-k2.6">Kimi K2.6</option>
									<option value="gpt-5.5-thinking">GPT-5.5 Thinking</option>
									<option value="custom">Custom</option>
								</select>
								<input type="text" name="selected_model_custom" placeholder="provider/model-id (used when Custom is selected)" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-200"/>
								<p class="text-xs text-gray-500">Custom model input is used only when <strong>Custom</strong> is selected above.</p>
								<button type="submit" class="btn-primary text-xs gap-1.5">
									@ActionIcon("settings", "relay-icon-sm")
									<span>Update Model</span>
								</button>
							}
						</div>
					</details>
				</div>
			}
			@StageEvidenceRow("not-available", "Branch / worktree", "", "") {
				if run.BranchName != "" {
					<span class="text-gray-200 font-mono break-all">{ run.BranchName }</span>
				} else {
					<span class="text-gray-600">not set</span>
				}
			}

			if artifactExists(artifacts, "opencode_handoff_packet") {
				@StageEvidenceRow("passed", "Packet artifacts", "", "") {
					@ArtifactPreviewLink(run.ID, "opencode_handoff_packet", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
						View Packet
					}
					<a href={"/runs/" + Itoa(run.ID) + "/artifacts/opencode_handoff_packet/download"}
						class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download Packet</a>
					if artifactExists(artifacts, "agent_prompt") {
						@ArtifactPreviewLink(run.ID, "agent_prompt", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View Agent Prompt
						}
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_prompt/download"}
							class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download Agent Prompt</a>
					}
				}
			}

			if previews.OpenCodeCommandPreview != "" {
				@StageEvidenceRow("ready", "Resolved OpenCode command", "The exact command Relay will use for execution.", "") {
					<div class="relay-stage-output-preview">
						<div class="p-3 space-y-2 text-xs sm:text-sm">
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Binary</span>
								<span class="text-gray-300 font-mono break-all">{ previews.OpenCodeBinary }</span>
							</div>
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Working directory</span>
								<span class="text-gray-300 font-mono break-all">{ previews.OpenCodeWorkDir }</span>
							</div>
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Agent</span>
								<span class="text-gray-300 font-mono break-all">{ previews.OpenCodeAgent }</span>
							</div>
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Model</span>
								<span class="text-gray-300 font-mono break-all">{ previews.OpenCodeModel }</span>
							</div>
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Thinking</span>
								<span class="text-gray-300 font-mono">{ previews.OpenCodeThinking }</span>
							</div>
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Prompt stdin</span>
								<span class="text-gray-300 font-mono break-all">{ previews.OpenCodeStdinSource } ({ previews.OpenCodeStdinBytes } bytes)</span>
							</div>
							<div class="pt-2 border-t border-gray-800">
								<div class="text-gray-400 mb-1">Command</div>
								<textarea readonly rows="2"
									class="w-full text-xs font-mono bg-gray-950 border border-gray-700 rounded-lg p-2 text-gray-300 select-all min-w-0 resize-y"
									onclick="this.select()">{ previews.OpenCodeCommandPreview }</textarea>
							</div>
						</div>
					</div>
				}
			}

			@StageEvidenceRow("ready", "OpenCode Adapter", "", "") {
				if previews.OpenCodeAdapterError == "" && previews.OpenCodeBinary != "" {
					<span class="relay-chip-green">ready</span>
				} else if previews.OpenCodeAdapterError != "" {
					<span class="relay-chip-red">blocked</span>
				} else {
					<span class="relay-chip-gray">pending</span>
				}
			}

			if previews.HasOpenCodeCLICheck {
				@StageEvidenceRow("passed", "OpenCode CLI Check", "", "") {
					<span class={ cliCheckStatusClass(previews.OpenCodeCLICheckStatus) }>{ previews.OpenCodeCLICheckStatus }</span>
				}
				@StageEvidenceRow("not-available", "CLI Check details", "", "") {
					<div class="space-y-1.5 text-xs sm:text-sm">
						<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
							<span class="text-gray-400 shrink-0">Binary</span>
							<span class="text-gray-300 font-mono break-all">{ previews.OpenCodeCLICheckBinary }</span>
						</div>
						if previews.OpenCodeCLICheckResolvedModel != "" {
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Resolved model</span>
								<span class="text-gray-300 font-mono break-all">{ previews.OpenCodeCLICheckResolvedModel }</span>
							</div>
						}
						<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
							<span class="text-gray-400 shrink-0">Model available</span>
							<span class={ cliCheckModelAvailableClass(previews.OpenCodeCLICheckModelAvailable) }>{ previews.OpenCodeCLICheckModelAvailable }</span>
						</div>
						if previews.OpenCodeCLICheckCheckedAt != "" {
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Checked at</span>
								<span class="text-gray-300">{ previews.OpenCodeCLICheckCheckedAt }</span>
							</div>
						}
						if previews.OpenCodeCLICheckError != "" {
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Error</span>
								<span class="text-red-400 break-all">{ previews.OpenCodeCLICheckError }</span>
							</div>
						}
					</div>
					<div class="relay-action-row mt-2">
						@ArtifactPreviewLink(run.ID, "opencode_cli_check_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View CLI check JSON
						}
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/opencode_cli_check_json/download"}
							class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download</a>
					</div>
				}
			}

			@StageEvidenceRow("ready", "Command actions", "", "") {
				<div class="relay-action-row">
					if previews.OpenCodeAdapterError == "" && previews.OpenCodeCommandPreview != "" {
						<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
							hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
							hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
							class="inline">
							<input type="hidden" name="action" value="dry-run-opencode-go"/>
							<button type="submit" class="btn-secondary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
								@ActionIcon("play", "relay-icon-sm")
								Dry Run / Preview Command
							</button>
						</form>
					} else {
						<span class="relay-chip-gray text-xs cursor-not-allowed"
							title={ "Dry Run unavailable: " + dryRunDisabledReason(previews) }>
							Dry Run / Preview Command (blocked)
						</span>
					}
					<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
						hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
						hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
						class="inline">
						<input type="hidden" name="action" value="check-opencode-cli"/>
						<button type="submit" class="btn-secondary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
							@ActionIcon("terminal", "relay-icon-sm")
							Check OpenCode CLI
						</button>
					</form>
				</div>
			}

			if previews.HasOpenCodeDryRun {
				@StageEvidenceRow("passed", "Dry Run Preview", "JSON summary. Does not execute OpenCode.", "") {
					<div class="relay-stage-output-preview">
						<div class="min-w-0 overflow-x-auto">
							<pre class="text-xs font-mono text-gray-300 whitespace-pre-wrap break-words max-h-40 p-3">{ previews.OpenCodeDryRunPreview }</pre>
						</div>
					</div>
					<div class="relay-action-row mt-2">
						@ArtifactPreviewLink(run.ID, "opencode_dry_run_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View
						}
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/opencode_dry_run_json/download"}
							class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download</a>
					</div>
				}
			}

			if previews.HasOpenCodeRunning {
				@StageEvidenceRow("running", "OpenCode is running", "", "") {
					@WorkbenchStepLink(run.ID, "run", "bot", "text-xs sm:text-sm text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						Monitor Agent Run
					}
				}
				@StageEvidenceRow("blocked", "Start OpenCode Go", "Already running.", "blocked")
			} else if previews.HasOpenCodeStaleRunning {
				{{ staleTitle := "OpenCode output stopped before a final result" }}
				{{ staleSummary := previews.OpenCodeStaleReason }}
				if previews.OpenCodeLifecycleState == "stale_timeout" {
					{{ staleTitle = "OpenCode execution exceeded timeout or Relay lost the worker" }}
					if staleSummary == "" {
						{{ staleSummary = "OpenCode is no longer plausibly active." }}
					}
				} else if staleSummary == "" {
					{{ staleSummary = "OpenCode stopped producing output before a final result." }}
				}
				@StageEvidenceRow("warning", staleTitle, staleSummary, "") {
					@WorkbenchStepLink(run.ID, "run", "bot", "text-xs sm:text-sm text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						Review Agent Run
					}
				}
				@StageEvidenceRow("blocked", "Start OpenCode Go", "Recover the stale run in Step 5 before starting a new one.", "blocked")
			} else if previews.OpenCodeAdapterError == "" && previews.HandoffPreflightStatus != "blocked" && previews.OpenCodeCommandPreview != "" {
				@StageEvidenceRow("ready", "Start OpenCode Go", "This starts a local OpenCode command. Relay will capture stdout/stderr as artifacts.", "") {
					<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
						hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
						hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true">
						<input type="hidden" name="action" value="start-opencode-go"/>
						<button type="submit" class="btn-primary text-sm sm:text-base w-full sm:w-auto gap-1.5" data-stage-primary-action>
							@ActionIcon("bot", "relay-icon-sm")
							Start OpenCode Go
						</button>
					</form>
				}
			} else if previews.HasOpenCodeExecution && !previews.HasOpenCodeRunning {
				@StageEvidenceRow("passed", "Latest OpenCode execution complete", "", "") {
					@WorkbenchStepLink(run.ID, "run", "bot", "text-xs sm:text-sm text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						Review Agent Run
					}
				}
				@StageEvidenceRow("blocked", "Start OpenCode Go", "Start unavailable: " + startDisabledReason(previews), "blocked") {
					<span class="relay-chip-gray text-xs cursor-not-allowed">Start OpenCode Go (blocked)</span>
				}
			}

			if previews.HasOpenCodeExecution {
				@StageEvidenceRow("passed", "Latest Execution", "", "") {
					<div class="relay-stage-output-preview">
						<div class="p-2 space-y-1.5 text-xs sm:text-sm">
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Status</span>
								<span class={ executionStatusClass(previews.OpenCodeExecutionStatus) }>{ previews.OpenCodeExecutionStatus }</span>
							</div>
							if previews.OpenCodeExecutionExitCode != "" {
								<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
									<span class="text-gray-400 shrink-0">Exit code</span>
									<span class="text-gray-300">{ previews.OpenCodeExecutionExitCode }</span>
								</div>
							}
							if previews.OpenCodeExecutionStarted != "" {
								<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
									<span class="text-gray-400 shrink-0">Started</span>
									<span class="text-gray-300">{ previews.OpenCodeExecutionStarted }</span>
								</div>
							}
							if previews.OpenCodeRuntime != "" {
								<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
									<span class="text-gray-400 shrink-0">Runtime</span>
									<span class="text-gray-300">{ previews.OpenCodeRuntime }</span>
								</div>
							}
							if previews.OpenCodeExecutionFinished != "" {
								<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
									<span class="text-gray-400 shrink-0">Finished</span>
									<span class="text-gray-300">{ previews.OpenCodeExecutionFinished }</span>
								</div>
							}
						</div>
					</div>
					<div class="relay-action-row mt-2">
						if previews.HasOpenCodeStdout {
							@ArtifactPreviewLink(run.ID, "opencode_stdout", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								stdout
							}
						}
						if previews.HasOpenCodeStderr {
							@ArtifactPreviewLink(run.ID, "opencode_stderr", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								stderr
							}
						}
						if previews.HasOpenCodeCombinedLog {
							@ArtifactPreviewLink(run.ID, "opencode_combined_log", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								combined log
							}
						}
					</div>
				}
			}

			<details class="m-4 relay-card p-3 sm:p-4">
				<summary class="cursor-pointer text-xs text-gray-500 hover:text-gray-300 list-none min-h-[36px] inline-flex items-center">
					Manual result intake fallback
				</summary>
				<div class="mt-3">
					<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
						hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
						hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
						class="space-y-3">
						<input type="hidden" name="action" value="submit-agent-result"/>
						<textarea name="agent_result_text" rows="6"
							class="w-full text-xs font-mono bg-gray-950 border border-gray-800 rounded-lg p-2 text-gray-300 min-w-0 resize-y"
							placeholder={"DONE\nBuild status: PASS\nTest status: PASS\nCount of LOC changed: 42"}></textarea>
						<button type="submit" class="btn-primary text-xs sm:text-sm" data-stage-primary-action>
							Save Agent Result
						</button>
					</form>

					if artifactExists(artifacts, "agent_result_raw") {
						<div class="mt-2 text-xs text-gray-500">
							Agent result received. Proceed to Relay Validation.
						</div>
						<div class="mt-2 pt-2 border-t border-gray-800 relay-action-row">
							@ArtifactPreviewLink(run.ID, "agent_result_raw", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								View raw result
							}
							<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_result_raw/download"}
								class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download raw result</a>
							if artifactExists(artifacts, "agent_result_json") {
								@ArtifactPreviewLink(run.ID, "agent_result_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
									View parsed JSON
								}
								<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_result_json/download"}
									class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download parsed JSON</a>
							}
						</div>
					}
				</div>
			</details>
		</div>
	</div>
}

func transcriptEventClass(kind string) string {
	switch kind {
	case "reasoning":
		return "text-gray-500"
	case "tool":
		return "text-indigo-400"
	case "text":
		return "text-green-300"
	case "stderr":
		return "text-red-400"
	case "step", "event", "raw":
		return "text-gray-400"
	default:
		return "text-gray-400"
	}
}

func openCodeLifecycleLabel(state string) string {
	switch state {
	case "active_streaming":
		return "streaming"
	case "active_output":
		return "output captured"
	case "running_no_output":
		return "starting"
	case "waiting_output":
		return "waiting for output"
	case "waiting_response":
		return "waiting for response"
	case "stale_output":
		return "stale output"
	case "stale_timeout":
		return "timed out"
	case "completed":
		return "completed"
	case "completed_without_result":
		return "completed without result"
	case "failed":
		return "failed"
	default:
		return "monitoring"
	}
}

func openCodeLifecycleDescription(previews RunPreviews) string {
	switch previews.OpenCodeLifecycleState {
	case "active_streaming":
		return "OpenCode is running and Relay is receiving streamed chunks."
	case "active_output":
		return "OpenCode is running and output artifacts are being updated."
	case "running_no_output":
		return "OpenCode is still inside the startup grace period and has not emitted output yet."
	case "waiting_output":
		return "OpenCode is running, but Relay has not seen output yet."
	case "waiting_response":
		return "OpenCode has gone quiet and may be waiting on a final response. Stop Waiting and Inspect Git Diff if the repo changes already look complete."
	case "stale_output":
		return "OpenCode stopped emitting output and may need recovery."
	case "stale_timeout":
		return "OpenCode exceeded the timeout window and may need recovery."
	case "completed":
		return "OpenCode finished and Relay will show the parsed result."
	case "completed_without_result":
		return "OpenCode finished, but Relay did not find a final DONE/BLOCKED result. Review the logs and inspect git diff before continuing."
	case "failed":
		return "OpenCode ended with a failure; review logs and artifacts."
	default:
		return "Relay is monitoring the execution."
	}
}

func openCodeTranscriptTail(events []OpenCodeTranscriptEventView, n int) []OpenCodeTranscriptEventView {
	if len(events) == 0 {
		return nil
	}
	if len(events) <= n {
		return events
	}
	return events[len(events)-n:]
}

func openCodeTrimEventText(text string, max int) string {
	if max <= 0 || len(text) <= max {
		return text
	}
	return text[:max] + "..."
}

func openCodeActivityLabel(kind string) string {
	switch kind {
	case "reasoning":
		return "agent internal update"
	case "tool":
		return "tool call"
	case "text":
		return "assistant output"
	case "stderr":
		return "stderr"
	case "step":
		return "step update"
	case "event":
		return "event"
	case "raw":
		return "raw output"
	default:
		return kind
	}
}

func openCodeCurrentActivity(events []OpenCodeTranscriptEventView) string {
	if len(events) == 0 {
		return ""
	}
	last := events[len(events)-1]
	label := openCodeActivityLabel(last.Kind)
	if label == "" {
		label = "activity"
	}
	detail := openCodeTrimEventText(last.Text, 120)
	if detail == "" {
		return label
	}
	return label + ": " + detail
}

templ openCodeStatusSummary(previews RunPreviews) {
	<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-3 sm:p-4">
		<div class="flex flex-wrap items-center gap-2">
			if previews.HasOpenCodeExecution {
				@openCodeExecutionStatusChip(previews.OpenCodeExecutionStatus)
			}
			<div class="text-sm font-medium text-gray-100 inline-flex items-center gap-1.5">
				@ActionIcon("bot", "relay-icon-sm")
				<span>OpenCode status</span>
			</div>
			if previews.OpenCodeLifecycleState != "" {
				<span class="relay-chip-gray text-[11px] gap-1.5">
					@StatusIcon("pending", "relay-icon-sm")
					<span>{ openCodeLifecycleLabel(previews.OpenCodeLifecycleState) }</span>
				</span>
			}
		</div>
		<div class="mt-3 grid gap-2 text-xs text-gray-300 sm:grid-cols-2 xl:grid-cols-3">
			if previews.OpenCodeCommandPreview != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Command:</span>
					<span class="font-mono break-all">{ previews.OpenCodeCommandPreview }</span>
				</div>
			}
			if previews.OpenCodeWorkDir != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Work dir:</span>
					<span class="font-mono break-all">{ previews.OpenCodeWorkDir }</span>
				</div>
			}
			if previews.OpenCodeModel != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Model:</span>
					<span class="font-mono break-all">{ previews.OpenCodeModel }</span>
				</div>
			}
			if previews.OpenCodeAgent != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Agent:</span>
					<span class="font-mono break-all">{ previews.OpenCodeAgent }</span>
				</div>
			}
			if previews.OpenCodeExecutionStarted != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Started:</span>
					<span>{ previews.OpenCodeExecutionStarted }</span>
				</div>
			}
			if previews.OpenCodeRuntime != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Runtime:</span>
					<span>{ previews.OpenCodeRuntime }</span>
				</div>
			}
			if previews.OpenCodeLastOutputAge != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Last output:</span>
					<span>{ previews.OpenCodeLastOutputAge }</span>
				</div>
			}
			if previews.OpenCodeStreamStdoutChunks > 0 || previews.OpenCodeStreamStderrChunks > 0 {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Chunks:</span>
					<span>
						if previews.OpenCodeStreamStdoutChunks > 0 {
							{"stdout " + Itoa(previews.OpenCodeStreamStdoutChunks)}
						}
						if previews.OpenCodeStreamStdoutChunks > 0 && previews.OpenCodeStreamStderrChunks > 0 {
							{" / "}
						}
						if previews.OpenCodeStreamStderrChunks > 0 {
							{"stderr " + Itoa(previews.OpenCodeStreamStderrChunks)}
						}
					</span>
				</div>
			}
			{{ activity := openCodeCurrentActivity(previews.OpenCodeTranscript) }}
			if activity != "" {
				<div class="flex gap-2 sm:col-span-2 xl:col-span-3">
					<span class="text-gray-500 shrink-0">Current activity:</span>
					<span class="text-gray-200">{ activity }</span>
				</div>
			}
		</div>
	</div>
}

templ openCodeActivityTimeline(events []OpenCodeTranscriptEventView) {
	{{ rows := openCodeTranscriptTail(events, 12) }}
	if len(rows) > 0 {
		<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-3 sm:p-4">
			<div class="text-sm font-medium text-gray-200 mb-2">Recent activity / timeline</div>
			<div class="space-y-0.5 text-xs leading-5 font-mono">
				for _, ev := range rows {
					<div class={ transcriptEventClass(ev.Kind) }>
						<span class="text-gray-600">{ "[" + openCodeActivityLabel(ev.Kind) + "]" }</span>
						<span class="whitespace-pre-wrap break-words">{ " " + openCodeTrimEventText(ev.Text, 180) }</span>
					</div>
				}
			</div>
		</div>
	}
}

templ openCodeRecentOutput(events []OpenCodeTranscriptEventView) {
	{{ rows := openCodeTranscriptTail(events, 6) }}
	if len(rows) > 0 {
		<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-3 sm:p-4">
			<div class="text-sm font-medium text-gray-200 mb-2">Recent output</div>
			<div class="space-y-0.5 text-xs leading-5 font-mono">
				for _, ev := range rows {
					<div class={ transcriptEventClass(ev.Kind) }>
						<span class="text-gray-600">{ "[" + ev.Kind + "]" }</span>
						<span class="whitespace-pre-wrap break-words">{ " " + openCodeTrimEventText(ev.Text, 220) }</span>
					</div>
				}
			</div>
		</div>
	}
}

templ AgentRunMonitorStepPanel(run *store.Run, artifacts []store.Artifact, checks []store.Check, previews RunPreviews) {
	<div id="agent-run-monitor" class="relay-card">
		@agentRunMonitorInner(run, artifacts, checks, previews, isExecutionRunning(previews.OpenCodeExecutionStatus))
	</div>
}

templ agentRunMonitorInner(run *store.Run, artifacts []store.Artifact, checks []store.Check, previews RunPreviews, isRunning bool) {
	<div class="relay-stage-evidence-list">
		if !previews.HasOpenCodeExecution {
			@StageEvidenceRow("warning", "No OpenCode run started yet", "Return to OpenCode to launch OpenCode Go.", "") {
				@WorkbenchStepLink(run.ID, "handoff", "terminal", "btn-primary text-xs sm:text-sm") {
					Back to OpenCode
				}
			}
		}
		if previews.HasOpenCodeExecution {
			@openCodeStatusSummary(previews)

			if isRunning && previews.OpenCodeLifecycleState == "waiting_response" {
				@StageEvidenceRow("warning", "OpenCode has stopped producing output but the process has not exited", "The agent may be waiting on a final response. Stop waiting to cancel Relay-owned execution and inspect git diff now.", "") {
					<div class="space-y-2">
						if previews.OpenCodeStreamLastChunkAge != "" {
							<div class="text-xs text-amber-200/90">Last streamed chunk: { previews.OpenCodeStreamLastChunkAge }</div>
						} else if previews.OpenCodeLastOutputAge != "" {
							<div class="text-xs text-amber-200/90">Last output: { previews.OpenCodeLastOutputAge }</div>
						}
						<div class="text-xs text-amber-200/90">
							Relay will cancel OpenCode if it is still running, preserve the terminal state, capture git evidence, and continue to Step 7.
						</div>
						@WorkbenchActionForm(run.ID, "stop-opencode-and-inspect-diff", "inline") {
							<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
								@ActionIcon("file-search", "relay-icon-sm")
								Stop Waiting and Inspect Git Diff
							</button>
						}
					</div>
				}
			} else if isRunning && previews.HasOpenCodeStaleRunning {
				{{ staleTitle := "OpenCode output stopped before a final result" }}
				{{ staleSummary := previews.OpenCodeStaleReason }}
				if previews.OpenCodeLifecycleState == "stale_timeout" {
					{{ staleTitle = "OpenCode execution exceeded timeout or Relay lost the worker" }}
					if staleSummary == "" {
						{{ staleSummary = "OpenCode is no longer plausibly active." }}
					}
				} else if staleSummary == "" {
					{{ staleSummary = "OpenCode stopped producing output before a final result." }}
				}
				{{ recoveryLabel := previews.OpenCodeRecoveryActionLabel }}
				if recoveryLabel == "" {
					{{ recoveryLabel = "Recover Stale OpenCode Run" }}
				}
				@StageEvidenceRow("warning", staleTitle, staleSummary, "") {
					<div class="space-y-2">
						if previews.OpenCodeStreamLastChunkAge != "" {
							<div class="text-xs text-amber-200/90">Last streamed chunk: { previews.OpenCodeStreamLastChunkAge }</div>
						} else if previews.OpenCodeLastOutputAge != "" {
							<div class="text-xs text-amber-200/90">Last output: { previews.OpenCodeLastOutputAge }</div>
						}
						<div class="text-xs text-amber-200/90">
							Review stdout, stderr, and the combined log, then recover this run or stop waiting and inspect git diff if the current changes are ready.
						</div>
						<div class="flex flex-wrap gap-2">
							@WorkbenchActionForm(run.ID, "recover-stale-opencode-execution", "inline") {
								<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
									@ActionIcon("life-buoy", "relay-icon-sm")
									{ recoveryLabel }
								</button>
							}
							@WorkbenchActionForm(run.ID, "stop-opencode-and-inspect-diff", "inline") {
								<button type="submit" class="btn-secondary text-xs sm:text-sm gap-1.5" data-stage-secondary-action>
									@ActionIcon("file-search", "relay-icon-sm")
									Stop Waiting and Inspect Git Diff
								</button>
							}
						</div>
					</div>
				}
			} else if isRunning {
				@StageEvidenceRow("running", "OpenCode activity", openCodeLifecycleDescription(previews), "") {
					<div class="text-xs text-blue-200 space-y-1">
						<div class="flex flex-wrap gap-x-4 gap-y-1">
							if previews.OpenCodeStreamStdoutChunks > 0 {
								<span>{ "stdout: " + Itoa(previews.OpenCodeStreamStdoutChunks) + " chunks (" + Itoa(previews.OpenCodeStreamStdoutBytes) + " bytes)" }</span>
							}
							if previews.OpenCodeStreamStderrChunks > 0 {
								<span>{ "stderr: " + Itoa(previews.OpenCodeStreamStderrChunks) + " chunks (" + Itoa(previews.OpenCodeStreamStderrBytes) + " bytes)" }</span>
							}
						</div>
						if previews.OpenCodeStreamLastChunkAge != "" {
							<div class="text-gray-400">Last chunk: { previews.OpenCodeStreamLastChunkAge }</div>
						}
					</div>
				}
			}

			if previews.OpenCodePermissionWarning != "" {
				@StageEvidenceRow("warning", previews.OpenCodePermissionWarning, "Review stderr or the combined log for the rejected request.", "")
			}

			if previews.OpenCodeExecutionStatus == "failed" {
				@StageFailurePanel("Execution failed", "") {
					if previews.OpenCodeFailureHint != "" {
						<div class="text-xs sm:text-sm text-red-200 mt-1">{ previews.OpenCodeFailureHint }</div>
					} else if previews.OpenCodeExecutionError != "" {
						<div class="text-xs sm:text-sm text-red-200 mt-1">{ previews.OpenCodeExecutionError }</div>
					} else if previews.OpenCodeExecutionExitCode != "" {
						<div class="text-xs sm:text-sm text-red-200 mt-1">
							OpenCode exited with code { previews.OpenCodeExecutionExitCode }.
						</div>
					} else {
						<div class="text-xs sm:text-sm text-red-200 mt-1">OpenCode failed. Review execution metadata.</div>
					}
					<div class="relay-action-row">
						if previews.HasOpenCodeStdout {
							@ArtifactPreviewLink(run.ID, "opencode_stdout", "text-xs text-red-300 hover:text-red-200 underline min-h-[36px] inline-flex items-center") {
								stdout
							}
						}
						if previews.HasOpenCodeStderr {
							@ArtifactPreviewLink(run.ID, "opencode_stderr", "text-xs text-red-300 hover:text-red-200 underline min-h-[36px] inline-flex items-center") {
								stderr
							}
						}
						if previews.HasOpenCodeCombinedLog {
							@ArtifactPreviewLink(run.ID, "opencode_combined_log", "text-xs text-red-300 hover:text-red-200 underline min-h-[36px] inline-flex items-center") {
								combined log
							}
						}
					</div>
				}
			}

			if len(previews.OpenCodeTranscript) > 0 {
				@openCodeActivityTimeline(previews.OpenCodeTranscript)
				@openCodeRecentOutput(previews.OpenCodeTranscript)
			}

			if previews.HasOpenCodeStdout || previews.HasOpenCodeStderr || previews.HasOpenCodeCombinedLog {
				@StageEvidenceRow("passed", "Log artifacts", "", "") {
					<div class="relay-action-row">
						if previews.HasOpenCodeStdout {
							@ArtifactPreviewLink(run.ID, "opencode_stdout", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								stdout
							}
							<a href={"/runs/" + Itoa(run.ID) + "/artifacts/opencode_stdout/download"}
								class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>download stdout</a>
						}
						if previews.HasOpenCodeStderr {
							@ArtifactPreviewLink(run.ID, "opencode_stderr", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								stderr
							}
							<a href={"/runs/" + Itoa(run.ID) + "/artifacts/opencode_stderr/download"}
								class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>download stderr</a>
						}
						if previews.HasOpenCodeCombinedLog {
							@ArtifactPreviewLink(run.ID, "opencode_combined_log", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								combined log
							}
							<a href={"/runs/" + Itoa(run.ID) + "/artifacts/opencode_combined_log/download"}
								class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>download combined log</a>
						}
					</div>
				}
			}

			if previews.OpenCodeParsedResultStatus != "" {
				@StageEvidenceRow("ready", "Parsed Result", "", "") {
					<div class="relay-stage-output-preview">
						<div class="p-3 space-y-2 text-xs sm:text-sm">
							<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
								<span class="text-gray-400 shrink-0">Status</span>
								<span class={ parsedResultStatusClass(previews.OpenCodeParsedResultStatus) }>{ previews.OpenCodeParsedResultStatus }</span>
							</div>
							if previews.OpenCodeParsedBuildStatus != "" {
								<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
									<span class="text-gray-400 shrink-0">Build</span>
									<span class="text-gray-300">{ previews.OpenCodeParsedBuildStatus }</span>
								</div>
							}
							if previews.OpenCodeParsedTestStatus != "" {
								<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
									<span class="text-gray-400 shrink-0">Tests</span>
									<span class="text-gray-300">{ previews.OpenCodeParsedTestStatus }</span>
								</div>
							}
							if previews.OpenCodeParsedLOCChanged != "" {
								<div class="flex flex-col sm:flex-row sm:justify-between gap-1">
									<span class="text-gray-400 shrink-0">LOC changed</span>
									<span class="text-gray-300">{ previews.OpenCodeParsedLOCChanged }</span>
								</div>
							}
						</div>
					</div>
					if previews.OpenCodeParsedResultRaw != "" {
						<div class="relay-action-row mt-2">
							@ArtifactPreviewLink(run.ID, "agent_result_raw", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								View raw result
							}
							<a href={"/runs/" + Itoa(run.ID) + "/artifacts/agent_result_raw/download"}
								class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download raw result</a>
						</div>
					}
					if previews.OpenCodeParsedResultStatus == "DONE" || previews.OpenCodeParsedResultStatus == "BLOCKED" {
						<div class="mt-3">
						@WorkbenchStepLink(run.ID, "validation", "clipboard-check", "btn-primary text-sm sm:text-base w-full sm:w-auto inline-flex items-center justify-center") {
							Proceed to Relay Validation
						}
						</div>
					}
				}
			}

			if previews.HasOpenCodeExecution && previews.OpenCodeLifecycleState == "completed_without_result" {
				if previews.HasGitChangeEvidence && (previews.GitChangeEvidenceMode == "no_changes" || previews.GitChangeEvidenceMode == "baseline_unavailable_no_changes") {
					@StageEvidenceRow("warning", "No repo changes detected", "OpenCode completed or stopped, and the captured git evidence shows a clean tree. The agent may have made no effective edit or reverted its change. Inspect git diff in Step 7 for details.", "") {
						<div class="relay-action-row">
							@WorkbenchStepLink(run.ID, "audit", "file-search", "text-xs text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
								Inspect Git Diff (Step 7)
							}
						</div>
					}
				} else {
					@StageEvidenceRow("warning", "OpenCode completed without a final DONE/BLOCKED result", "Relay did not find a DONE/BLOCKED final response in the captured output. The agent may have finished its work but Relay cannot parse the result. Review the combined log and inspect git diff to verify changes.", "") {
						<div class="space-y-2">
							<div class="relay-action-row">
								@WorkbenchStepLink(run.ID, "audit", "file-search", "text-xs text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
									Inspect Git Diff (Step 7)
								}
							</div>
							<div class="relay-card p-3 sm:p-4">
								<div class="text-xs text-gray-500 mb-3 font-medium">Manual result intake fallback</div>
								<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
									hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
									hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
									class="space-y-3">
									<input type="hidden" name="action" value="submit-agent-result"/>
									<textarea name="agent_result_text" rows="6"
										class="w-full text-xs font-mono bg-gray-950 border border-gray-800 rounded-lg p-2 text-gray-300 min-w-0 resize-y"
										placeholder={"DONE\nBuild status: PASS\nTest status: PASS\nCount of LOC changed: 42"}></textarea>
									<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
										@ActionIcon("play", "relay-icon-sm")
										Save Agent Result
									</button>
								</form>
							</div>
						</div>
					}
				}
			} else {
				<details class="m-4 relay-card p-3 sm:p-4">
					<summary class="cursor-pointer text-xs text-gray-500 hover:text-gray-300 list-none min-h-[36px] inline-flex items-center">
						Manual result intake fallback
					</summary>
					<div class="mt-3">
						<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
							hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
							hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
							class="space-y-3">
							<input type="hidden" name="action" value="submit-agent-result"/>
							<textarea name="agent_result_text" rows="6"
								class="w-full text-xs font-mono bg-gray-950 border border-gray-800 rounded-lg p-2 text-gray-300 min-w-0 resize-y"
								placeholder={"DONE\nBuild status: PASS\nTest status: PASS\nCount of LOC changed: 42"}></textarea>
							<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
								@ActionIcon("play", "relay-icon-sm")
								Save Agent Result
							</button>
						</form>
					</div>
				</details>
			}
		}
	</div>
}

templ RelayValidationStepPanel(run *store.Run, artifacts []store.Artifact, checks []store.Check, previews RunPreviews) {
	<div id="relay-validation-panel" class="relay-card">
		@relayValidationStepPanelInner(run, artifacts, checks, previews)
	</div>
}

templ relayValidationStepPanelInner(run *store.Run, artifacts []store.Artifact, checks []store.Check, previews RunPreviews) {
	<div class="relay-card-header">
			<div class="flex flex-wrap items-center gap-2 sm:gap-3">
				@validationStatusChip(artifactExists(artifacts, "validation_run_json"), checks, artifactExists(artifacts, "agent_result_raw"), previews.ValidationProgressRunning)
				if previews.ValidationProgressRunning {
					<span class="relay-chip-blue text-xs">running</span>
				} else if artifactExists(artifacts, "agent_result_raw") && previews.HasValidationCommands {
					<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
						hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
						hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
						class="inline">
						<input type="hidden" name="action" value="run-validation"/>
						<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
							@ActionIcon("play", "relay-icon-sm")
							Run Validation Commands
						</button>
					</form>
				} else if artifactExists(artifacts, "agent_result_raw") && !previews.HasValidationCommands {
					<span class="relay-chip-gray text-xs cursor-not-allowed"
						title="No validation commands available">
						Run Validation (no commands)
					</span>
				} else {
					<span class="relay-chip-gray text-xs cursor-not-allowed"
						title="Submit an agent result first">
						Run Validation (no result)
					</span>
				}
			</div>
		</div>

		<div class="relay-stage-evidence-list">
			if previews.ValidationProgressStale {
				@StageEvidenceRow("warning", "Validation may be stale", "Last update was " + previews.ValidationProgressPreview.UpdatedAt + ". If validation appears stuck, check events/logs and re-run.", "") {
					if artifactExists(artifacts, "agent_result_raw") && previews.HasValidationCommands {
						<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
							hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
							hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
							class="inline">
							<input type="hidden" name="action" value="run-validation"/>
							<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
								@ActionIcon("rotate-ccw", "relay-icon-sm")
								Re-run Validation
							</button>
						</form>
					}
				}
			}
			if previews.ValidationProgressRunning {
				@StageEvidenceRow("running", "Validation live progress", "Live updates refresh this panel while validation commands are active.", "") {
					@validationProgressDisplay(previews.ValidationProgressPreview, run.ID, artifacts, previews)
				}
			} else if previews.ValidationProgressPreview.Status == "error" {
				@StageFailurePanel("Validation error", previews.ValidationProgressPreview.Error) {
					if artifactExists(artifacts, "agent_result_raw") && previews.HasValidationCommands {
						<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
							hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
							hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
							class="inline">
							<input type="hidden" name="action" value="run-validation"/>
							<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
								@ActionIcon("rotate-ccw", "relay-icon-sm")
								Retry Validation
							</button>
						</form>
					}
				}
			} else if artifactExists(artifacts, "validation_run_json") && previews.ValidationRun.CommandCount > 0 {
				if previews.ValidationRun.Status == "fail" {
					for _, cmd := range previews.ValidationRun.Commands {
						if cmd.Status == "fail" || cmd.Status == "timed_out" {
							@StageFailurePanel("Failed command", "") {
								<div class="text-xs text-red-200">
									Command: <span class="font-mono break-all">{ cmd.Command }</span>
									&middot; exit { Itoa(int64(cmd.ExitCode)) }
									&middot; { Itoa(cmd.DurationMs) }ms
								</div>
								<div class="relay-action-row mt-2">
									if cmd.HasStdout {
										@ArtifactPreviewLink(run.ID, "validation_stdout", "text-xs text-red-300 hover:text-red-200 underline min-h-[36px] inline-flex items-center") {
											stdout
										}
									}
									if cmd.HasStderr {
										@ArtifactPreviewLink(run.ID, "validation_stderr", "text-xs text-red-300 hover:text-red-200 underline min-h-[36px] inline-flex items-center") {
											stderr
										}
									}
								</div>
							}
						}
					}
				}
				@StageEvidenceRow("passed", "Validation results", "", "") {
					@validationResultsSummary(previews.ValidationRun, run.ID, artifacts)
				}
				@validationRecentOutput(previews, run.ID, artifacts)
			} else if artifactExists(artifacts, "validation_run_json") {
				@StageEvidenceRow("passed", "Validation completed", "", "") {
					if hasCheckStatus(checks, "validation_run", "pass") {
						<div class="text-xs text-green-400">Validation passed.</div>
					} else if hasCheckStatus(checks, "validation_run", "fail") {
						<div class="text-xs text-red-400">Validation failed. Review stdout/stderr artifacts.</div>
					} else {
						<div class="text-xs text-gray-500">Validation completed. Check artifacts for details.</div>
					}
					<div class="mt-2 text-xs text-yellow-400">Validation result artifact could not be parsed. Use View validation JSON.</div>
				}
				@validationRecentOutput(previews, run.ID, artifacts)
			} else if validationProgressFinished(previews) {
				if previews.ValidationProgressPreview.Status == "pass" {
					@StageEvidenceRow("passed", "Validation passed", "", "")
				} else {
					@StageEvidenceRow("failed", "Validation failed", "Review stdout/stderr artifacts.", "")
				}
				if !artifactExists(artifacts, "validation_run_json") {
					@StageEvidenceRow("warning", "Result artifact missing", "Validation finished but final result artifact is missing. Check events/logs.", "")
				}
			} else if !artifactExists(artifacts, "agent_result_raw") {
				@StageEvidenceRow("pending", "Agent result needed", "Submit an agent result first, then run validation commands.", "")
			} else if !previews.HasValidationCommands {
				@StageFailurePanel("No validation commands", "Add a validation section to the handoff or configure default validation commands for this repo.") {
					<a href="/settings/repos" class="text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Repository settings</a>
				}
			} else {
				@StageEvidenceRow("ready", "Agent result received", "Run validation commands to verify the changes.", "")
			}
			if artifactExists(artifacts, "validation_run_json") {
				@StageEvidenceRow("passed", "Validation artifacts", "", "") {
					<div class="relay-action-row">
						@ArtifactPreviewLink(run.ID, "validation_run_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View validation JSON
						}
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/validation_run_json/download"}
							class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download validation JSON</a>
						@ArtifactPreviewLink(run.ID, "validation_stdout", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View stdout
						}
						@ArtifactPreviewLink(run.ID, "validation_stderr", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
							View stderr
						}
					</div>
				}

				if previews.ValidationRun.Status == "pass" {
					@auditHandoffSection(previews, run.ID)
				}
				if previews.ValidationRun.Status == "fail" && !previews.ValidationFailedAccepted {
					@StageFailurePanel("Validation failed", "Review the validation output. Use accept only when you intentionally want to continue with a failed validation.") {
						<form action={"/runs/" + Itoa(run.ID) + "/actions"} method="POST"
							hx-post={"/runs/" + Itoa(run.ID) + "/actions"}
							hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
							class="inline">
							<input type="hidden" name="action" value="accept-validation-failure"/>
							<button type="submit" class="btn-secondary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
								@ActionIcon("badge-check", "relay-icon-sm")
								Accept Failed Validation and Continue to Diff / Audit
							</button>
						</form>
					}
				}
				if previews.ValidationRun.Status == "fail" && previews.ValidationFailedAccepted {
					@StageEvidenceRow("warning", "Validation failure accepted", "Continue to Step 7: Diff / Audit.", "") {
						@WorkbenchStepLink(run.ID, "audit", "file-search", "btn-primary text-xs sm:text-sm") {
							Go to Step 7: Diff / Audit
						}
					}
				}
			}
		</div>
}
templ validationResultsSummary(v ValidationRunPreview, runID int64, artifacts []store.Artifact) {
	<div class="rounded-xl border border-gray-800 bg-gray-950/40 overflow-hidden">
		<div class="border-b border-gray-800 px-3 py-2 flex items-center justify-between">
			<div class="min-w-0">
				<div class="text-sm font-medium">
					if v.Status == "pass" {
						<span class="text-green-400">Validation passed</span>
					} else {
						<span class="text-red-400">Validation failed</span>
					}
				</div>
				<div class="text-xs text-gray-500">
					{ Itoa(int64(v.CommandCount)) } commands
					&middot; { Itoa(int64(v.PassedCount)) } passed
					&middot; { Itoa(int64(v.FailedCount)) } failed
					&middot; { Itoa(int64(v.TimedOutCount)) } timed out
					&middot; { formatDuration(v.TotalDurationMs) }
				</div>
			</div>
		</div>
		<div class="divide-y divide-gray-800">
			for _, cmd := range v.Commands {
				<div class="px-3 py-2 flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 text-xs">
					<div class="flex items-center gap-2 min-w-0 flex-1">
						@validationCommandStatusChip(cmd.Status)
						<span class="text-gray-200 font-mono truncate min-w-0">{ cmd.Command }</span>
					</div>
					<div class="flex items-center gap-2 sm:gap-3 text-gray-500 shrink-0 ml-0 sm:ml-auto">
						if cmd.Source != "" {
							<span class="hidden sm:inline">{ cmd.Source }</span>
						}
						<span>exit { Itoa(int64(cmd.ExitCode)) }</span>
						<span class="tabular-nums">{ formatDuration(cmd.DurationMs) }</span>
						if cmd.HasStdout {
							@ArtifactPreviewLink(runID, "validation_stdout", "text-indigo-400 hover:text-indigo-300 underline") {
								stdout
							}
						}
						if cmd.HasStderr {
							@ArtifactPreviewLink(runID, "validation_stderr", "text-red-400 hover:text-red-300 underline") {
								stderr
							}
						}
					</div>
				</div>
			}
		</div>
	</div>
}

templ validationCommandStatusChip(status string) {
	if status == "pass" {
		<span class="relay-chip-green shrink-0 gap-1.5">
			@StatusIcon("passed", "relay-icon-sm")
			<span>passed</span>
		</span>
	} else if status == "fail" {
		<span class="relay-chip-red shrink-0 gap-1.5">
			@StatusIcon("failed", "relay-icon-sm")
			<span>failed</span>
		</span>
	} else if status == "timed_out" {
		<span class="relay-chip-yellow shrink-0 gap-1.5">
			@StatusIcon("warning", "relay-icon-sm")
			<span>timed out</span>
		</span>
	} else if status == "running" {
		<span class="relay-chip-blue shrink-0 gap-1.5">
			@StatusIcon("running", "relay-icon-sm")
			<span>running</span>
		</span>
	} else if status == "pending" {
		<span class="relay-chip-gray shrink-0 gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>pending</span>
		</span>
	} else if status == "skipped" {
		<span class="relay-chip-gray shrink-0 gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>skipped</span>
		</span>
	} else if status == "error" {
		<span class="relay-chip-red shrink-0 gap-1.5">
			@StatusIcon("failed", "relay-icon-sm")
			<span>error</span>
		</span>
	} else {
		<span class="relay-chip-gray shrink-0 gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>{ status }</span>
		</span>
	}
}

templ validationProgressDisplay(progress ValidationProgressPreview, runID int64, artifacts []store.Artifact, previews RunPreviews) {
	<div class="rounded-xl border border-blue-900/60 bg-blue-950/30 p-3 sm:p-4">
		<div class="flex flex-wrap items-center gap-2 sm:gap-3">
			<span class="relay-chip-blue text-xs gap-1.5">
				@StatusIcon("running", "relay-icon-sm")
				<span>running</span>
			</span>
			<div class="text-sm font-medium text-blue-300">Validation live progress</div>
		</div>
		<div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-300">
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Started:</span>
				<span>{ progress.StartedAt }</span>
			</div>
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Updated:</span>
				<span>{ progress.UpdatedAt }</span>
			</div>
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Elapsed:</span>
				<span>{ validationProgressElapsed(progress) }</span>
			</div>
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Current:</span>
				if progress.CurrentCommand != "" {
					<span class="text-blue-200 font-mono break-all">{ progress.CurrentCommand }</span>
				} else {
					<span class="text-gray-500">Waiting</span>
				}
			</div>
		</div>
		<div class="mt-3 text-xs text-gray-400">
			{ Itoa(int64(progress.TotalCommands)) } commands
			&middot; { Itoa(int64(progress.CompletedCount)) } completed
			&middot; { Itoa(int64(progress.RunningCount)) } running
			&middot; { Itoa(int64(progress.PendingCount)) } pending
		</div>
		<div class="mt-2 text-xs text-gray-400">
			{ Itoa(int64(progress.PassedCount)) } passed
			&middot; { Itoa(int64(progress.FailedCount)) } failed
			&middot; { Itoa(int64(progress.TimedOutCount)) } timed out
			if progress.SkippedCount > 0 {
				&middot; { Itoa(int64(progress.SkippedCount)) } skipped
			}
			if progress.ErrorCount > 0 {
				&middot; { Itoa(int64(progress.ErrorCount)) } error
			}
		</div>
	</div>
	if previews.ValidationStdoutPreview != "" || previews.ValidationStderrPreview != "" {
		<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-3 sm:p-4">
			<div class="text-sm font-medium text-gray-200 mb-2">Recent output</div>
			<div class="space-y-3 text-xs leading-5">
				if previews.ValidationStdoutPreview != "" {
					<div class="space-y-1">
						<div class="text-gray-500 uppercase tracking-wide">stdout</div>
						<pre class="text-gray-300 whitespace-pre-wrap break-words max-h-48 overflow-auto">{ previews.ValidationStdoutPreview }</pre>
					</div>
				}
				if previews.ValidationStderrPreview != "" {
					<div class="space-y-1">
						<div class="text-gray-500 uppercase tracking-wide">stderr</div>
						<pre class="text-gray-300 whitespace-pre-wrap break-words max-h-48 overflow-auto">{ previews.ValidationStderrPreview }</pre>
					</div>
				}
			</div>
			<div class="mt-3 flex flex-wrap items-center gap-2 text-xs">
				if artifactExists(artifacts, "validation_run_json") {
					@ArtifactPreviewLink(runID, "validation_run_json", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						validation JSON
					}
				}
				if artifactExists(artifacts, "validation_stdout") {
					@ArtifactPreviewLink(runID, "validation_stdout", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						stdout
					}
				}
				if artifactExists(artifacts, "validation_stderr") {
					@ArtifactPreviewLink(runID, "validation_stderr", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						stderr
					}
				}
			</div>
		</div>
	}
	if len(progress.Commands) > 0 {
		<div class="rounded-xl border border-gray-800 bg-gray-950/40 overflow-hidden">
			<div class="border-b border-gray-800 px-3 py-2 flex items-center justify-between">
				<div class="text-sm font-medium text-gray-200">Commands</div>
				if progress.CurrentIndex > 0 {
					<div class="text-xs text-gray-500">
						Step { Itoa(int64(progress.CurrentIndex)) } of { Itoa(int64(progress.TotalCommands)) }
					</div>
				}
			</div>
			<div class="divide-y divide-gray-800">
				for _, cmd := range progress.Commands {
					<div class="px-3 py-2 flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 text-xs">
						<div class="flex items-center gap-2 min-w-0 flex-1">
							@validationCommandStatusChip(cmd.Status)
							<div class="min-w-0">
								<div class="font-mono text-gray-200 truncate min-w-0">{ cmd.Command }</div>
								if cmd.Label != "" && cmd.Label != cmd.Command {
									<div class="text-[11px] text-gray-500 truncate">{ cmd.Label }</div>
								}
							</div>
						</div>
						<div class="flex flex-wrap items-center gap-2 sm:gap-3 text-gray-500 shrink-0 ml-0 sm:ml-auto">
							if cmd.Source != "" {
								<span>{ cmd.Source }</span>
							}
							if cmd.StartedAt != "" {
								<span class="hidden xl:inline">{ cmd.StartedAt }</span>
							}
							if cmd.Status != "pending" && cmd.Status != "running" {
								<span>exit { Itoa(int64(cmd.ExitCode)) }</span>
							}
							if validationProgressCommandDuration(cmd) != "" {
								<span class="tabular-nums">{ validationProgressCommandDuration(cmd) }</span>
							}
							if cmd.HasStdout && artifactExists(artifacts, "validation_stdout") {
								@ArtifactPreviewLink(runID, "validation_stdout", "text-indigo-400 hover:text-indigo-300 underline") {
									stdout
								}
							}
							if cmd.HasStderr && artifactExists(artifacts, "validation_stderr") {
								@ArtifactPreviewLink(runID, "validation_stderr", "text-red-400 hover:text-red-300 underline") {
									stderr
								}
							}
						</div>
					</div>
				}
			</div>
		</div>
	}
	if artifactExists(artifacts, "validation_run_json") || artifactExists(artifacts, "validation_stdout") || artifactExists(artifacts, "validation_stderr") {
		<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-3">
			<div class="text-xs text-gray-500 uppercase tracking-wide mb-2">Artifacts</div>
			<div class="flex flex-wrap items-center gap-2 text-xs">
				if artifactExists(artifacts, "validation_run_json") {
					@ArtifactPreviewLink(runID, "validation_run_json", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						validation JSON
					}
				}
				if artifactExists(artifacts, "validation_stdout") {
					@ArtifactPreviewLink(runID, "validation_stdout", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						stdout
					}
				}
				if artifactExists(artifacts, "validation_stderr") {
					@ArtifactPreviewLink(runID, "validation_stderr", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						stderr
					}
				}
			</div>
		</div>
	}
}

templ validationRecentOutput(previews RunPreviews, runID int64, artifacts []store.Artifact) {
	if previews.ValidationStdoutPreview != "" || previews.ValidationStderrPreview != "" {
		<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-3 sm:p-4">
			<div class="text-sm font-medium text-gray-200 mb-2">Recent output</div>
			<div class="space-y-3 text-xs leading-5">
				if previews.ValidationStdoutPreview != "" {
					<div class="space-y-1">
						<div class="text-gray-500 uppercase tracking-wide">stdout</div>
						<pre class="text-gray-300 whitespace-pre-wrap break-words max-h-48 overflow-auto">{ previews.ValidationStdoutPreview }</pre>
					</div>
				}
				if previews.ValidationStderrPreview != "" {
					<div class="space-y-1">
						<div class="text-gray-500 uppercase tracking-wide">stderr</div>
						<pre class="text-gray-300 whitespace-pre-wrap break-words max-h-48 overflow-auto">{ previews.ValidationStderrPreview }</pre>
					</div>
				}
			</div>
			<div class="mt-3 flex flex-wrap items-center gap-2 text-xs">
				if artifactExists(artifacts, "validation_run_json") {
					@ArtifactPreviewLink(runID, "validation_run_json", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						validation JSON
					}
				}
				if artifactExists(artifacts, "validation_stdout") {
					@ArtifactPreviewLink(runID, "validation_stdout", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						stdout
					}
				}
				if artifactExists(artifacts, "validation_stderr") {
					@ArtifactPreviewLink(runID, "validation_stderr", "text-indigo-400 hover:text-indigo-300 underline min-h-[36px] inline-flex items-center") {
						stderr
					}
				}
			</div>
		</div>
	}
}

templ auditHandoffSection(previews RunPreviews, runID int64) {
	if previews.HasAuditHandoff {
		<div class="rounded-xl border border-green-900/60 bg-green-950/30 p-3 sm:p-4">
			<div class="text-sm font-medium text-green-300">Audit handoff ready</div>
			<p class="mt-1 text-xs text-green-200">
				Copy the audit handoff into GPT for review.
			</p>
			<div class="mt-2 flex flex-wrap items-center gap-2">
				@ArtifactPreviewLink(runID, "audit_handoff", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
					View audit handoff
				}
				<a href={"/runs/" + Itoa(runID) + "/artifacts/audit_handoff/download"}
					class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center">Download audit handoff</a>
			</div>
			if previews.AuditHandoff != "" {
				<details class="mt-2">
					<summary class="cursor-pointer text-xs text-gray-500 hover:text-gray-300 list-none min-h-[36px] inline-flex items-center">
						Preview audit handoff
					</summary>
					<div class="mt-2 relay-card p-3 max-h-60 overflow-auto min-w-0">
						<pre class="text-xs font-mono text-gray-300 whitespace-pre-wrap break-words">{ previews.AuditHandoff }</pre>
					</div>
				</details>
			}
		</div>
	} else {
		<div class="rounded-xl border border-indigo-900/60 bg-indigo-950/30 p-3 sm:p-4">
			<div class="text-sm font-medium text-indigo-300">Validation passed</div>
			<p class="mt-1 text-xs text-indigo-200">
				Validation passed. Generate an audit handoff to review this run in GPT.
			</p>
			<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
				hx-post={"/runs/" + Itoa(runID) + "/actions"}
				hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
				class="mt-2">
				<input type="hidden" name="action" value="generate-audit-handoff"/>
						<button type="submit"
					class="btn-primary text-xs sm:text-sm gap-1.5">
						@ActionIcon("scroll-text", "relay-icon-sm")
					Generate Audit Handoff
				</button>
			</form>
		</div>
	}
}

func formatDuration(ms int64) string {
	if ms < 1000 {
		return Itoa(ms) + "ms"
	}
	sec := float64(ms) / 1000.0
	if sec < 60 {
		return fmt.Sprintf("%.1fs", sec)
	}
	min := int64(sec) / 60
	rem := int64(sec) % 60
	return Itoa(min) + "m " + Itoa(rem) + "s"
}

templ changeEvidenceDisplay(previews RunPreviews) {
	<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-3 sm:p-4">
		<div class="text-sm font-medium text-indigo-300 mb-2">Change evidence</div>
		<div class="space-y-1.5 text-xs">
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Mode:</span>
				<span class={ changeEvidenceModeClass(previews.GitChangeEvidenceMode) }>{ formattedEvidenceMode(previews.GitChangeEvidenceMode) }</span>
			</div>
			if previews.GitChangeEvidenceBaseline != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Baseline:</span>
					<span class="text-gray-300 font-mono">{ shortSHA(previews.GitChangeEvidenceBaseline) }</span>
				</div>
			}
			if previews.GitChangeEvidenceHead != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Current HEAD:</span>
					<span class="text-gray-300 font-mono">{ shortSHA(previews.GitChangeEvidenceHead) }</span>
				</div>
			}
			if previews.GitChangeEvidenceBranch != "" {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Branch:</span>
					<span class="text-gray-300 font-mono">{ previews.GitChangeEvidenceBranch }</span>
				</div>
			}
			if previews.GitChangeEvidenceCommitCnt > 0 {
				<div class="flex gap-2">
					<span class="text-gray-500 shrink-0">Commits:</span>
					<span class="text-gray-300">{ Itoa(int64(previews.GitChangeEvidenceCommitCnt)) }</span>
				</div>
			}
			if previews.GitChangeEvidenceWarning != "" {
				<div class="mt-2 text-xs text-amber-200 bg-amber-950/30 rounded-lg p-2">
					{ previews.GitChangeEvidenceWarning }
				</div>
			}
		</div>
	</div>
}

templ DiffAuditStepPanel(previews RunPreviews, runID int64) {
	<div class="relay-card">
		<div class="relay-card-header">
			if previews.HasAuditHandoff {
				<span class="relay-chip-green text-xs">ready</span>
			} else if previews.HasGitStatus {
				<span class="relay-chip-blue text-xs">diff ready</span>
			} else {
				<span class="relay-chip-gray text-xs">pending</span>
			}
			<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
				hx-post={"/runs/" + Itoa(runID) + "/actions"}
				hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
				class="inline">
				<input type="hidden" name="action" value="inspect-diff"/>
				<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
					@ActionIcon("file-search", "relay-icon-sm")
					if previews.HasGitStatus {
						Re-inspect Git Diff
					} else {
						Inspect Git Diff
					}
				</button>
			</form>
		</div>

		<div class="relay-stage-evidence-list">
			if previews.HasGitChangeEvidence {
				@changeEvidenceDisplay(previews)
			}

			if previews.HasGitStatus || previews.HasGitDiffStat || previews.HasGitDiffPatch {
				@StageEvidenceRow("ready", "Git diff evidence ready", "Collects git status and diff artifacts. Does not modify the worktree.", "") {
					if previews.GitChangedFileCount > 0 {
						<span class="text-xs text-gray-400 relay-stage-meta">Changed files: { Itoa(previews.GitChangedFileCount) }</span>
					}
				}
				if previews.GitDiffSummary != "" {
					@StageEvidenceRow("not-available", "Diff summary", previews.GitDiffSummary, "")
				}
				@StageEvidenceRow("passed", "Git artifacts", "", "") {
					<div class="relay-action-row">
						if previews.HasGitStatus {
							@ArtifactPreviewLink(runID, "git_status_text", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								View status
							}
						}
						if previews.HasGitDiffStat {
							@ArtifactPreviewLink(runID, "git_diff_stat", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								View diff stat
							}
						}
						if previews.HasGitDiffPatch {
							@ArtifactPreviewLink(runID, "git_diff_patch", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
								View patch
							}
							<a href={"/runs/" + Itoa(runID) + "/artifacts/git_diff_patch/download"}
								class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download patch</a>
						}
					</div>
				}

				if previews.GitStatusPreview != "" {
					@StageEvidenceRow("not-available", "Git status preview", "", "") {
						<div class="relay-stage-output-preview">
							<div class="max-h-40 overflow-auto min-w-0">
								<pre class="text-xs leading-5 font-mono p-3 text-gray-300 whitespace-pre-wrap break-words">{ previews.GitStatusPreview }</pre>
							</div>
						</div>
					}
				}
				if previews.GitDiffStatPreview != "" {
					@StageEvidenceRow("not-available", "Diff stat preview", "", "") {
						<div class="relay-stage-output-preview">
							<div class="max-h-40 overflow-auto min-w-0">
								<pre class="text-xs leading-5 font-mono p-3 text-gray-300 whitespace-pre-wrap break-words">{ previews.GitDiffStatPreview }</pre>
							</div>
						</div>
					}
				}
			} else {
				@StageEvidenceRow("pending", "Git diff not inspected", "Collects git status and diff artifacts from the selected repo path. Does not modify the worktree.", "")
			}

			if previews.HasAuditHandoff {
				@StageEvidenceRow("ready", "Audit handoff ready", "Copy the audit handoff into GPT for review.", "") {
					@ArtifactPreviewLink(runID, "audit_handoff", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
						View audit handoff
					}
					<a href={"/runs/" + Itoa(runID) + "/artifacts/audit_handoff/download"}
						class="text-xs text-gray-500 hover:text-gray-300 min-h-[36px] inline-flex items-center" data-stage-artifact-link>Download audit handoff</a>
				}
				if previews.AuditHandoff != "" {
					@StageEvidenceRow("not-available", "Audit handoff preview", "Copy the content below and paste it into GPT for review.", "") {
						<div class="relay-stage-output-preview">
							<div class="max-h-80 overflow-auto min-w-0">
								<pre class="text-xs leading-5 font-mono p-3 text-gray-300 whitespace-pre-wrap break-words select-all">{ previews.AuditHandoff }</pre>
							</div>
						</div>
					}
				}
			}

			if previews.GitChangeEvidenceMode == "mixed_committed_and_uncommitted" {
				@StageFailurePanel("Audit blocked: mixed committed and uncommitted changes", "") {
					<div class="text-xs text-amber-200">
						Committed changes exist since the baseline, but the working tree is also dirty.
						Resolve uncommitted changes (commit, stash, or discard), then rerun Inspect Git Diff.
					</div>
				}
			} else if previews.GitChangeEvidenceMode == "no_changes" || previews.GitChangeEvidenceMode == "baseline_unavailable_no_changes" {
				{{ btnLabel := "Generate Audit Handoff" }}
				if previews.HasAuditHandoff {
					btnLabel = "Regenerate Audit Handoff"
				}
				@StageEvidenceRow("warning", "No repo changes detected", "OpenCode completed or stopped, but git status is clean. The agent may have made no effective edit or reverted its change. You can still generate an audit handoff with the available metadata.", "") {
					<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
						hx-post={"/runs/" + Itoa(runID) + "/actions"}
						hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
						class="inline">
						<input type="hidden" name="action" value="generate-audit-handoff"/>
						<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
							@ActionIcon("scroll-text", "relay-icon-sm")
							{ btnLabel }
						</button>
					</form>
				}
			} else {
				{{ auditSummary := "Generate the audit handoff after collecting git diff evidence." }}
				if previews.HasAuditHandoff {
					auditSummary = "Regenerate after inspecting git diff."
				}
				@StageEvidenceRow("ready", "Audit action", auditSummary, "") {
					<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
						hx-post={"/runs/" + Itoa(runID) + "/actions"}
						hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
						class="inline">
						<input type="hidden" name="action" value="generate-audit-handoff"/>
						<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
							@ActionIcon("scroll-text", "relay-icon-sm")
							if previews.HasAuditHandoff {
								Regenerate Audit Handoff
							} else {
								Generate Audit Handoff
							}
						</button>
					</form>
				}
			}

			@auditDecisionSection(previews, runID)
		</div>
	</div>
}

templ auditDecisionSection(previews RunPreviews, runID int64) {
	if previews.HasAuditHandoff {
		if previews.AuditClearanceStatus == "accepted" {
			@StageEvidenceRow("passed", "Audit accepted", "External audit clearance is recorded.", "") {
				if previews.AuditClearanceSource != "" || previews.AuditClearanceAcceptedAt != "" {
					<span class="text-xs text-gray-400 relay-stage-meta">
						if previews.AuditClearanceSource != "" {
							Source: { previews.AuditClearanceSource }
						}
					if previews.AuditClearanceSource != "" && previews.AuditClearanceAcceptedAt != "" {
						{" | "}
					}
						if previews.AuditClearanceAcceptedAt != "" {
							Accepted at { previews.AuditClearanceAcceptedAt }
						}
					</span>
				}
				<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
					hx-post={"/runs/" + Itoa(runID) + "/actions"}
					hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
					class="inline">
					<input type="hidden" name="action" value="revoke-audit-clearance"/>
					<button type="submit" class="btn-secondary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
						@ActionIcon("rotate-ccw", "relay-icon-sm")
						Revoke Audit Acceptance
					</button>
				</form>
			}
		} else {
			@StageEvidenceRow("warning", "Audit clearance pending", "Review the audit handoff and mark the decision here before continuing.", "") {
				<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
					hx-post={"/runs/" + Itoa(runID) + "/actions"}
					hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
					class="inline">
					<input type="hidden" name="action" value="accept-audit-clearance"/>
					<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
						@ActionIcon("badge-check", "relay-icon-sm")
						Mark Audit Accepted
					</button>
				</form>
			}
		}
	}
}

templ GitCommitStepPanel(run *store.Run, artifacts []store.Artifact, previews RunPreviews) {
	<div class="relay-card">
		<div class="relay-card-header">
			@commitStatusChip(previews)
		</div>

		<div class="relay-stage-evidence-list">
			@commitStateSummary(previews)

			if previews.CommitState == "blocked_validation" {
				@StageEvidenceRow("blocked", "Validation required", "Run Relay Validation in Step 6 before committing or pushing.", "") {
						@WorkbenchStepLink(run.ID, "validation", "clipboard-check", "btn-primary text-xs sm:text-sm") {
							Go to Step 6: Relay Validation
						}
				}
			}

			if previews.CommitState == "blocked_no_diff_inspection" {
				@StageEvidenceRow("warning", "Git diff not inspected", "Run Inspect Git Diff in Step 7 before committing.", "") {
						@WorkbenchStepLink(run.ID, "audit", "file-search", "btn-primary text-xs sm:text-sm") {
							Go to Step 7: Diff / Audit
						}
				}
			}

			if previews.CommitState == "blocked_audit_not_accepted" {
				@StageEvidenceRow("warning", "Audit clearance needed", "Review the audit handoff in Step 7 and mark the decision there before commit or push.", "") {
						@WorkbenchStepLink(run.ID, "audit", "file-search", "btn-primary text-xs sm:text-sm") {
							Go to Step 7: Diff / Audit
						}
				}
			}

			if previews.AuditClearanceStatus == "accepted" {
				@StageEvidenceRow("passed", "Audit accepted", "Audit clearance has been granted.", "") {
					if previews.AuditClearanceSource != "" || previews.AuditClearanceAcceptedAt != "" {
						<span class="text-xs text-gray-400 relay-stage-meta">
							if previews.AuditClearanceSource != "" {
								Source: { previews.AuditClearanceSource }
							}
							if previews.AuditClearanceSource != "" && previews.AuditClearanceAcceptedAt != "" {
								{" | "}
							}
							if previews.AuditClearanceAcceptedAt != "" {
								Accepted at { previews.AuditClearanceAcceptedAt }
							}
						</span>
					}
				}
			} else {
				@StageEvidenceRow("warning", "Audit clearance pending", "Review the audit handoff in Step 7 before committing or pushing.", "") {
					if previews.HasAuditHandoff {
						<span class="text-xs text-gray-400 relay-stage-meta">Audit handoff is ready. Complete the decision in Step 7.</span>
					} else {
						<span class="text-xs text-gray-400 relay-stage-meta">Generate the audit handoff in Step 7 before continuing.</span>
					}
				}
			}

			if previews.CommitState == "blocked_mixed_changes" {
				@StageFailurePanel("Mixed committed and uncommitted changes", "") {
					<div class="text-xs text-amber-200">
						Committed changes exist since the baseline, but the working tree is also dirty.
						Commit, stash, or discard uncommitted changes, then rerun Inspect Git Diff in Step 7.
					</div>
				}
			}

			if previews.CommitState == "blocked_no_upstream" {
				@StageEvidenceRow("blocked", "No upstream configured", "Set an upstream branch to enable push.", "") {
					<div class="text-xs text-gray-400">
						Run <code class="text-gray-300">git push -u origin { previews.CommitBranch }</code> in the repo to set an upstream, then return here.
					</div>
				}
			}

			if previews.CommitState == "no_changes" {
				@StageEvidenceRow("warning", "No changes to commit", "No git diff evidence detected. The agent may have made no effective edit or reverted its change. Run Inspect Git Diff in Step 7.", "")
			}

			@commitEvidenceDetails(previews, run.ID)

			@commitMessageSuggestion(previews, run.ID)

			@commitActions(previews, run.ID)

			@pushActions(previews, run.ID)

			@commitPushResults(previews, run.ID)

			@commitArtifactLinks(previews, run.ID)
		</div>
	</div>
}

templ commitStatusChip(previews RunPreviews) {
	switch previews.CommitState {
	case "pushed":
		<span class="relay-chip-green text-xs gap-1.5">
			@StatusIcon("done", "relay-icon-sm")
			<span>pushed</span>
		</span>
	case "committed_local":
		<span class="relay-chip-blue text-xs gap-1.5">
			@StatusIcon("done", "relay-icon-sm")
			<span>committed</span>
		</span>
	case "ready_to_commit":
		<span class="relay-chip-indigo text-xs gap-1.5">
			@StatusIcon("ready", "relay-icon-sm")
			<span>ready</span>
		</span>
	case "commit_failed":
		<span class="relay-chip-red text-xs gap-1.5">
			@StatusIcon("failed", "relay-icon-sm")
			<span>failed</span>
		</span>
	case "push_failed":
		<span class="relay-chip-red text-xs gap-1.5">
			@StatusIcon("failed", "relay-icon-sm")
			<span>push failed</span>
		</span>
	case "blocked_validation", "blocked_audit_not_accepted", "blocked_no_diff_inspection", "blocked_mixed_changes", "blocked_no_upstream":
		<span class="relay-chip-gray text-xs gap-1.5">
			@StatusIcon("blocked", "relay-icon-sm")
			<span>blocked</span>
		</span>
	case "no_changes":
		<span class="relay-chip-gray text-xs gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>no changes</span>
		</span>
	case "unknown":
		<span class="relay-chip-gray text-xs gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>unknown</span>
		</span>
	default:
		if previews.HasCommitSuggestion {
			<span class="relay-chip-green text-xs gap-1.5">
				@StatusIcon("ready", "relay-icon-sm")
				<span>ready</span>
			</span>
		} else {
			<span class="relay-chip-gray text-xs gap-1.5">
				@StatusIcon("pending", "relay-icon-sm")
				<span>pending</span>
			</span>
		}
	}
}

templ commitStateSummary(previews RunPreviews) {
	<div class="rounded-xl border border-gray-800 bg-gray-950/40 p-3 space-y-1.5 text-xs">
		<div class="flex gap-2">
			<span class="text-gray-500 shrink-0">Commit state:</span>
			<span class={ commitStateClass(previews.CommitState) + " inline-flex items-center gap-1.5" }>
				@StatusIcon(previews.CommitState, "relay-icon-sm")
				<span>{ commitStateLabel(previews.CommitState) }</span>
			</span>
		</div>
		if previews.CommitStateMsg != "" {
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">State detail:</span>
				<span class="text-red-300">{ previews.CommitStateMsg }</span>
			</div>
		}
		<div class="flex gap-2">
			<span class="text-gray-500 shrink-0">Validation:</span>
			if previews.CommitValidationPassed || previews.ValidationFailedAccepted {
				<span class="inline-flex items-center gap-1.5 text-green-400">
					@StatusIcon("passed", "relay-icon-sm")
					<span>passed</span>
				</span>
			} else if previews.ValidationRun.Status == "fail" {
				<span class="inline-flex items-center gap-1.5 text-red-400">
					@StatusIcon("failed", "relay-icon-sm")
					<span>failed</span>
				</span>
			} else {
				<span class="inline-flex items-center gap-1.5 text-gray-500">
					@StatusIcon("pending", "relay-icon-sm")
					<span>pending</span>
				</span>
			}
		</div>
		<div class="flex gap-2">
			<span class="text-gray-500 shrink-0">Audit clearance:</span>
			if previews.AuditClearanceStatus == "accepted" {
				<span class="inline-flex items-center gap-1.5 text-green-400">
					@StatusIcon("passed", "relay-icon-sm")
					<span>accepted</span>
				</span>
			} else {
				<span class="inline-flex items-center gap-1.5 text-yellow-300">
					@StatusIcon("warning", "relay-icon-sm")
					<span>pending</span>
				</span>
				if previews.HasAuditHandoff {
					<span class="text-gray-400">review the audit handoff in Step 7.</span>
				} else {
					<span class="text-gray-400">generate the audit handoff in Step 7.</span>
				}
			}
		</div>
		<div class="flex gap-2">
			<span class="text-gray-500 shrink-0">Change evidence:</span>
			<span class={ changeEvidenceModeClass(previews.CommitEvidenceMode) + " inline-flex items-center gap-1.5" }>
				@ActionIcon("file-diff", "relay-icon-sm")
				<span>{ formattedEvidenceMode(previews.CommitEvidenceMode) }</span>
			</span>
		</div>
		if previews.CommitUpstreamRemote != "" && previews.CommitUpstreamBranch != "" {
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Upstream:</span>
				<span class="inline-flex items-center gap-1.5 text-gray-300">
					@ActionIcon("git-branch", "relay-icon-sm")
					<span>{ previews.CommitUpstreamRemote }/{ previews.CommitUpstreamBranch }</span>
				</span>
			</div>
		}
		if previews.CommitAheadCount > 0 {
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Ahead:</span>
				<span class="text-gray-300">{ Itoa(int64(previews.CommitAheadCount)) } commit(s)</span>
			</div>
		}
		if previews.CommitBehindCount > 0 {
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Behind:</span>
				<span class="text-yellow-300">{ Itoa(int64(previews.CommitBehindCount)) } commit(s)</span>
			</div>
		}
		if previews.CommitBranch != "" {
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Branch:</span>
				<span class="text-gray-300 font-mono">{ previews.CommitBranch }</span>
			</div>
		}
		if previews.CommitHeadSHA != "" {
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">HEAD:</span>
				<span class="text-gray-300 font-mono">{ shortSHA(previews.CommitHeadSHA) }</span>
			</div>
		}
		if previews.CommitSHA != "" {
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Commit:</span>
				<span class="text-gray-300 font-mono">{ shortSHA(previews.CommitSHA) }</span>
			</div>
		}
		if previews.CommitSubject != "" {
			<div class="flex gap-2">
				<span class="text-gray-500 shrink-0">Subject:</span>
				<span class="text-gray-300">{ previews.CommitSubject }</span>
			</div>
		}
	</div>
}

templ commitEvidenceDetails(previews RunPreviews, runID int64) {
	if previews.HasGitChangeEvidence {
		@changeEvidenceDisplay(previews)
	}
}

templ commitMessageSuggestion(previews RunPreviews, runID int64) {
	if previews.CommitSuggestionSelected != "" {
		@StageEvidenceRow("passed", "Selected commit message", "Source: " + previews.CommitSuggestionSource + " (confidence: " + previews.CommitSuggestionConfidence + ")", "") {
			<textarea readonly rows="2"
				class="w-full text-xs font-mono bg-gray-950 border border-gray-700 rounded-lg p-2 text-gray-300 select-all min-w-0 resize-y"
				onclick="this.select()">{ previews.CommitSuggestionSelected }</textarea>
		}

		if len(previews.CommitWarnings) > 0 {
			for _, w := range previews.CommitWarnings {
				@StageEvidenceRow("warning", w, "", "")
			}
		}
	} else if (previews.CommitState == "ready_to_commit" || previews.CommitState == "") && previews.HasGitStatus && previews.HasAuditHandoff {
		@StageEvidenceRow("ready", "Prepare Git Commit", "Reviews the handoff, audit handoff, and git diff evidence, then generates a suggested commit message.", "") {
			<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
				hx-post={"/runs/" + Itoa(runID) + "/actions"}
				hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
				class="inline">
				<input type="hidden" name="action" value="prepare-git-commit"/>
				<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
					@ActionIcon("file-search", "relay-icon-sm")
					Prepare Git Commit
				</button>
			</form>
		}
	}
}

templ commitActions(previews RunPreviews, runID int64) {
	if previews.CommitState == "ready_to_commit" && previews.CommitSuggestionSelected != "" {
		@StageEvidenceRow("ready", "Create Commit", "Creates a commit with the selected message. Relay runs `git add -A && git commit`.", "") {
			<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
				hx-post={"/runs/" + Itoa(runID) + "/actions"}
				hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
				class="inline">
				<input type="hidden" name="action" value="create-git-commit"/>
				<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
					@ActionIcon("git-commit", "relay-icon-sm")
					Create Commit
				</button>
			</form>
			@manualCommitCommand(previews)
		}
	} else if previews.CommitState == "ready_to_commit" && previews.CommitSuggestionSelected == "" {
		@StageEvidenceRow("ready", "Manual commit", "Prepare a commit suggestion first, or run the commands manually.", "") {
			@manualCommitCommand(previews)
		}
	} else if previews.CommitState == "committed_local" || previews.CommitState == "pushed" {
		@manualCommitCopyCommand(previews)
	}
}

templ manualCommitCommand(previews RunPreviews) {
	<div class="mt-2">
		<div class="text-xs text-gray-400 mb-1">Manual commit command:</div>
		<textarea readonly rows="3"
			class="w-full text-xs font-mono bg-gray-950 border border-gray-700 rounded-lg p-2 text-gray-300 select-all min-w-0 resize-y"
			onclick="this.select()">git add -A
git commit -m "{ previews.CommitSuggestionSelected }"</textarea>
	</div>
}

templ manualCommitCopyCommand(previews RunPreviews) {
	@StageEvidenceRow("not-available", "Manual fallback", "Commit verified in worktree.", "") {
		if previews.RepoPath != "" {
			<div class="text-xs text-gray-400 mb-1">Repo path: <span class="text-gray-300 font-mono">{ previews.RepoPath }</span></div>
		}
		if previews.CommitResultSHA != "" {
			<div class="text-xs text-gray-400 mb-1">Commit: <span class="text-gray-300 font-mono">{ shortSHA(previews.CommitResultSHA) }</span></div>
		}
		if previews.CommitResultSubject != "" {
			<div class="text-xs text-gray-400 mb-1">Subject: <span class="text-gray-300">{ previews.CommitResultSubject }</span></div>
		}
		if previews.CommitState == "committed_local" {
			<div class="text-xs text-blue-300">Use <strong>Push to Upstream</strong> above or run <code class="text-gray-300">git push</code> from the repo.</div>
		} else if previews.CommitState == "pushed" {
			<div class="text-xs text-green-400">Changes have been pushed.</div>
		}
	}
}

templ pushActions(previews RunPreviews, runID int64) {
	if previews.CommitState == "committed_local" && previews.CommitHasUpstream {
		@StageEvidenceRow("ready", "Push to Upstream", "Pushes the local commit to the upstream branch.", "") {
			<form action={"/runs/" + Itoa(runID) + "/actions"} method="POST"
				hx-post={"/runs/" + Itoa(runID) + "/actions"}
				hx-target="#run-workbench-shell" hx-select="#run-workbench-shell" hx-swap="outerHTML show:#run-workbench-shell:top settle:120ms" hx-indicator="#run-workbench-loading" data-relay-workbench-action="true"
				class="inline">
				<input type="hidden" name="action" value="push-git-commit"/>
				<button type="submit" class="btn-primary text-xs sm:text-sm gap-1.5" data-stage-primary-action>
					@ActionIcon("upload-cloud", "relay-icon-sm")
					Push to Upstream
				</button>
			</form>
		}
	} else if previews.CommitState == "committed_local" && !previews.CommitHasUpstream {
		@StageEvidenceRow("blocked", "Push blocked", "No upstream configured for this branch.", "") {
			<div class="text-xs text-gray-400">
				Run <code class="text-gray-300">git push -u origin { previews.CommitBranch }</code> in the repo to set an upstream.
			</div>
		}
	}
}

templ commitPushResults(previews RunPreviews, runID int64) {
	if previews.HasCommitResult {
		if previews.CommitResultSuccess {
			@StageEvidenceRow("passed", "Commit created", "SHA: " + shortSHA(previews.CommitResultSHA) + " - " + previews.CommitResultSubject, "") {
				@ArtifactPreviewLink(runID, "git_commit_result_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
					View commit result
				}
			}
		} else {
			@StageEvidenceRow("failed", "Commit failed", "Review the commit result artifact for details.", "") {
				@ArtifactPreviewLink(runID, "git_commit_result_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
					View commit result
				}
			}
		}
	}

	if previews.HasPushDryRun {
		if previews.PushDryRunPass {
			@StageEvidenceRow("passed", "Push dry run passed", "", "")
		} else {
			@StageEvidenceRow("warning", "Push dry run failed", "Review push result artifact for details.", "") {
				@ArtifactPreviewLink(runID, "git_push_dry_run_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
					View dry run
				}
			}
		}
	}

	if previews.HasPushResult {
		if previews.PushResultSuccess {
			@StageEvidenceRow("passed", "Push succeeded", "Changes pushed to upstream.", "") {
				@ArtifactPreviewLink(runID, "git_push_result_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
					View push result
				}
			}
		} else {
			@StageEvidenceRow("failed", "Push failed", "Review the push result artifact for details.", "") {
				@ArtifactPreviewLink(runID, "git_push_result_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
					View push result
				}
			}
		}
	}
}

templ commitArtifactLinks(previews RunPreviews, runID int64) {
	if previews.HasCommitSuggestion || previews.HasCommitResult || previews.HasPushResult {
		@StageEvidenceRow("passed", "Commit / Push artifacts", "", "") {
			<div class="relay-action-row">
				if previews.HasGitStatus {
					@ArtifactPreviewLink(runID, "git_status_text", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
						Git status
					}
				}
				if previews.HasGitDiffStat {
					@ArtifactPreviewLink(runID, "git_diff_stat", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
						Diff stat
					}
				}
				@ArtifactPreviewLink(runID, "audit_handoff", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
					Audit handoff
				}
				if previews.HasCommitSuggestion {
					@ArtifactPreviewLink(runID, "commit_suggestion_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
						Commit suggestion
					}
				}
				if previews.HasCommitResult {
					@ArtifactPreviewLink(runID, "git_commit_result_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
						Commit result
					}
				}
				if previews.HasPushResult {
					@ArtifactPreviewLink(runID, "git_push_result_json", "text-xs text-indigo-400 hover:text-indigo-300 min-h-[36px] inline-flex items-center") {
						Push result
					}
				}
			</div>
		}
	}
}

func commitStateClass(state string) string {
	switch state {
	case "pushed":
		return "text-green-400"
	case "committed_local":
		return "text-blue-300"
	case "ready_to_commit":
		return "text-indigo-300"
	case "commit_failed", "push_failed":
		return "text-red-400"
	case "blocked_validation", "blocked_audit_not_accepted", "blocked_no_diff_inspection", "blocked_mixed_changes", "blocked_no_upstream":
		return "text-red-300"
	case "no_changes":
		return "text-yellow-300"
	case "unknown":
		return "text-gray-500"
	default:
		return "text-gray-400"
	}
}

func commitStateLabel(state string) string {
	switch state {
	case "blocked_validation":
		return "Blocked: validation required"
	case "blocked_audit_not_accepted":
		return "Blocked: audit not accepted"
	case "blocked_no_diff_inspection":
		return "Blocked: inspect git diff first"
	case "blocked_mixed_changes":
		return "Blocked: mixed committed + uncommitted"
	case "blocked_no_upstream":
		return "Blocked: no upstream configured"
	case "no_changes":
		return "No changes"
	case "unknown":
		return "Commit state unavailable"
	case "ready_to_commit":
		return "Ready to commit"
	case "committed_local":
		return "Committed locally"
	case "pushed":
		return "Pushed"
	case "push_failed":
		return "Push failed"
	case "commit_failed":
		return "Commit failed"
	default:
		return state
	}
}

templ intakeStatusChip(checks []store.Check) {
	if hasCheckStatus(checks, "validation", "block") {
		<span class="relay-chip-red gap-1.5">
			@StatusIcon("blocked", "relay-icon-sm")
			<span>blocked</span>
		</span>
	} else if hasCheckStatus(checks, "validation", "warn") {
		<span class="relay-chip-yellow gap-1.5">
			@StatusIcon("warning", "relay-icon-sm")
			<span>warn</span>
		</span>
	} else if hasCheckStatus(checks, "validation", "pass") {
		<span class="relay-chip-green gap-1.5">
			@StatusIcon("passed", "relay-icon-sm")
			<span>pass</span>
		</span>
	} else if hasCheckStatus(checks, "validation", "fail") {
		<span class="relay-chip-red gap-1.5">
			@StatusIcon("failed", "relay-icon-sm")
			<span>blocked</span>
		</span>
	} else {
		<span class="relay-chip-gray gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>pending</span>
		</span>
	}
}

templ agentPromptStatusChip(hasAgentPrompt bool, checks []store.Check) {
	if hasAgentPrompt {
		<span class="relay-chip-green gap-1.5">
			@StatusIcon("ready", "relay-icon-sm")
			<span>ready</span>
		</span>
	} else if hasCheckStatus(checks, "validation", "block") || hasCheckStatus(checks, "validation", "fail") {
		<span class="relay-chip-red gap-1.5">
			@StatusIcon("blocked", "relay-icon-sm")
			<span>blocked</span>
		</span>
	} else {
		<span class="relay-chip-gray gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>pending</span>
		</span>
	}
}

templ agentPacketStatusChip(hasPacket, hasPrompt bool) {
	if hasPacket {
		<span class="relay-chip-green gap-1.5">
			@StatusIcon("ready", "relay-icon-sm")
			<span>ready</span>
		</span>
	} else if hasPrompt {
		<span class="relay-chip-blue gap-1.5">
			@StatusIcon("ready", "relay-icon-sm")
			<span>available</span>
		</span>
	} else {
		<span class="relay-chip-gray gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>pending</span>
		</span>
	}
}

templ handoffPreflightStatusChip(status string) {
	if status == "ready" {
		<span class="relay-chip-green gap-1.5">
			@StatusIcon("ready", "relay-icon-sm")
			<span>ready</span>
		</span>
	} else if status == "blocked" {
		<span class="relay-chip-red gap-1.5">
			@StatusIcon("blocked", "relay-icon-sm")
			<span>blocked</span>
		</span>
	} else if status == "warning" {
		<span class="relay-chip-yellow gap-1.5">
			@StatusIcon("warning", "relay-icon-sm")
			<span>warning</span>
		</span>
	}
}

templ handoffStatusChip(hasPacket bool) {
	if hasPacket {
		<span class="relay-chip-green gap-1.5">
			@StatusIcon("ready", "relay-icon-sm")
			<span>packet ready</span>
		</span>
	} else {
		<span class="relay-chip-gray gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>no packet</span>
		</span>
	}
}

templ validationStatusChip(hasRun bool, checks []store.Check, hasAgentResult bool, isRunning bool) {
	if isRunning {
		<span class="relay-chip-blue gap-1.5">
			@StatusIcon("running", "relay-icon-sm")
			<span>running</span>
		</span>
	} else if hasRun {
		if hasCheckStatus(checks, "validation_run", "pass") {
			<span class="relay-chip-green gap-1.5">
				@StatusIcon("passed", "relay-icon-sm")
				<span>passed</span>
			</span>
		} else if hasCheckStatus(checks, "validation_run", "fail") {
			<span class="relay-chip-red gap-1.5">
				@StatusIcon("failed", "relay-icon-sm")
				<span>failed</span>
			</span>
		} else {
			<span class="relay-chip-blue gap-1.5">
				@StatusIcon("done", "relay-icon-sm")
				<span>ran</span>
			</span>
		}
	} else if hasAgentResult {
		<span class="relay-chip-blue gap-1.5">
			@StatusIcon("ready", "relay-icon-sm")
			<span>available</span>
		</span>
	} else {
		<span class="relay-chip-gray gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>pending</span>
		</span>
	}
}

func hasCheckKind(checks []store.Check, kind string) bool {
	for _, c := range checks {
		if c.Kind == kind {
			return true
		}
	}
	return false
}

func hasCheckStatus(checks []store.Check, kind, status string) bool {
	for _, c := range checks {
		if c.Kind == kind && c.Status == status {
			return true
		}
	}
	return false
}

func artifactExists(artifacts []store.Artifact, kind string) bool {
	for _, a := range artifacts {
		if a.Kind == kind {
			return true
		}
	}
	return false
}

templ openCodeExecutionStatusChip(status string) {
	if status == "completed" {
		<span class="relay-chip-green gap-1.5">
			@StatusIcon("done", "relay-icon-sm")
			<span>completed</span>
		</span>
	} else if status == "failed" {
		<span class="relay-chip-red gap-1.5">
			@StatusIcon("failed", "relay-icon-sm")
			<span>failed</span>
		</span>
	} else if status == "starting" {
		<span class="relay-chip-blue gap-1.5">
			@StatusIcon("active", "relay-icon-sm")
			<span>starting</span>
		</span>
	} else if status == "running" {
		<span class="relay-chip-blue gap-1.5">
			@StatusIcon("running", "relay-icon-sm")
			<span>running</span>
		</span>
	} else if status == "blocked" {
		<span class="relay-chip-red gap-1.5">
			@StatusIcon("blocked", "relay-icon-sm")
			<span>blocked</span>
		</span>
	} else {
		<span class="relay-chip-gray gap-1.5">
			@StatusIcon("pending", "relay-icon-sm")
			<span>{ status }</span>
		</span>
	}
}

func executionStatusClass(status string) string {
	switch status {
	case "completed":
		return "text-green-400"
	case "failed", "blocked":
		return "text-red-400"
	case "running", "starting":
		return "text-blue-400"
	default:
		return "text-gray-400"
	}
}

func cliCheckStatusClass(status string) string {
	switch status {
	case "pass":
		return "relay-chip-green"
	case "warn":
		return "relay-chip-yellow"
	case "fail":
		return "relay-chip-red"
	default:
		return "relay-chip-gray"
	}
}

func isExecutionRunning(status string) bool {
	return status == "starting" || status == "running"
}

func parsedResultStatusClass(status string) string {
	switch status {
	case "DONE":
		return "text-green-400"
	case "BLOCKED":
		return "text-red-400"
	default:
		return "text-yellow-400"
	}
}

func cliCheckModelAvailableClass(available string) string {
	switch available {
	case "yes":
		return "text-green-400"
	case "no":
		return "text-red-400"
	default:
		return "text-gray-500"
	}
}

func dryRunDisabledReason(previews RunPreviews) string {
	if previews.OpenCodeAdapterError != "" {
		return "adapter blocked: " + previews.OpenCodeAdapterError
	}
	if previews.OpenCodeCommandPreview == "" {
		return "no command preview; complete earlier steps first"
	}
	return "not available"
}

func startDisabledReason(previews RunPreviews) string {
	if previews.OpenCodeAdapterError != "" {
		return "adapter blocked: " + previews.OpenCodeAdapterError
	}
	if previews.HandoffPreflightStatus == "blocked" {
		return "handoff preflight checks are blocked"
	}
	if previews.OpenCodeCommandPreview == "" {
		return "no command preview; complete earlier steps first"
	}
	return "not available"
}

type relayValidationUIState string

const (
	relayValidationNoResult   relayValidationUIState = "no_result"
	relayValidationNoCommands relayValidationUIState = "no_commands"
	relayValidationReady      relayValidationUIState = "ready"
	relayValidationCompleted  relayValidationUIState = "completed"
)

func changeEvidenceModeClass(mode string) string {
	switch mode {
	case "no_changes":
		return "text-gray-500"
	case "uncommitted_worktree", "baseline_unavailable_uncommitted":
		return "text-yellow-300"
	case "committed_range":
		return "text-green-300"
	case "mixed_committed_and_uncommitted":
		return "text-red-300"
	default:
		return "text-gray-400"
	}
}

func formattedEvidenceMode(mode string) string {
	switch mode {
	case "no_changes":
		return "No changes"
	case "uncommitted_worktree":
		return "Uncommitted worktree"
	case "committed_range":
		return "Committed range"
	case "mixed_committed_and_uncommitted":
		return "Mixed: committed + uncommitted"
	case "baseline_unavailable_uncommitted":
		return "Baseline unavailable (uncommitted)"
	case "baseline_unavailable_no_changes":
		return "Baseline unavailable (no changes)"
	default:
		return mode
	}
}

func validationProgressFinished(previews RunPreviews) bool {
	return previews.HasValidationProgress && (previews.ValidationProgressPreview.Status == "pass" || previews.ValidationProgressPreview.Status == "fail")
}

func validationProgressElapsed(progress ValidationProgressPreview) string {
	startedAt, err := time.Parse(time.RFC3339, progress.StartedAt)
	if err != nil || startedAt.IsZero() {
		return ""
	}
	endValue := progress.UpdatedAt
	if progress.FinishedAt != "" {
		endValue = progress.FinishedAt
	}
	if endValue == "" {
		endValue = time.Now().UTC().Format(time.RFC3339)
	}
	endedAt, err := time.Parse(time.RFC3339, endValue)
	if err != nil || endedAt.IsZero() {
		return ""
	}
	if endedAt.Before(startedAt) {
		return ""
	}
	return formatDuration(endedAt.Sub(startedAt).Milliseconds())
}

func validationProgressCommandDuration(cmd ValidationProgressCommandView) string {
	if cmd.DurationMs > 0 {
		return formatDuration(cmd.DurationMs)
	}
	if cmd.Status == "running" && cmd.StartedAt != "" {
		startedAt, err := time.Parse(time.RFC3339, cmd.StartedAt)
		if err != nil || startedAt.IsZero() {
			return ""
		}
		elapsed := time.Since(startedAt.UTC()).Milliseconds()
		if elapsed < 0 {
			return ""
		}
		return formatDuration(elapsed)
	}
	if cmd.StartedAt != "" && cmd.CompletedAt != "" {
		startedAt, err := time.Parse(time.RFC3339, cmd.StartedAt)
		if err != nil || startedAt.IsZero() {
			return ""
		}
		completedAt, err := time.Parse(time.RFC3339, cmd.CompletedAt)
		if err != nil || completedAt.IsZero() {
			return ""
		}
		if completedAt.Before(startedAt) {
			return ""
		}
		return formatDuration(completedAt.Sub(startedAt).Milliseconds())
	}
	return ""
}

func relayValidationUIStateFor(hasAgentResult bool, hasValidationCommands bool, hasValidationRun bool) relayValidationUIState {
	if hasValidationRun {
		return relayValidationCompleted
	}
	if !hasAgentResult {
		return relayValidationNoResult
	}
	if !hasValidationCommands {
		return relayValidationNoCommands
	}
	return relayValidationReady
}

func stageEvidenceTitleClass(status string) string {
	switch status {
	case "passed":
		return "text-green-300"
	case "failed", "blocked":
		return "text-red-300"
	case "warning":
		return "text-yellow-300"
	case "running":
		return "text-blue-300"
	case "ready":
		return "text-indigo-300"
	case "pending":
		return "text-gray-400"
	default:
		return "text-gray-200"
	}
}

templ StageEvidenceRow(status string, title string, summary string, meta string) {
	<div class={"relay-stage-evidence-row relay-stage-evidence-row-" + status} data-stage-evidence-row>
		<div class="flex items-start gap-2 sm:gap-3 min-w-0 w-full">
			<span class={"relay-stage-evidence-symbol relay-stage-evidence-symbol-" + status}>
				@StatusIcon(status, "relay-icon-sm")
			</span>
			<div class="min-w-0 flex-1">
				<div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-2">
					<span class={"text-sm font-medium " + stageEvidenceTitleClass(status)}>{ title }</span>
					if meta != "" {
						<span class="relay-stage-meta">{ meta }</span>
					}
				</div>
				if summary != "" {
					<p class="text-xs text-gray-400 mt-0.5 break-words">{ summary }</p>
				}
				<div class="relay-action-row mt-1.5" data-stage-evidence-actions>
					{ children... }
				</div>
			</div>
		</div>
	</div>
}

templ StageFailurePanel(title string, summary string) {
	<div class="relay-stage-failure-panel" data-stage-failure-panel>
		<div class="flex items-start gap-2">
						<span class="relay-stage-evidence-symbol relay-stage-evidence-symbol-blocked shrink-0 mt-0.5">
				@StatusIcon("blocked", "relay-icon-sm")
			</span>
			<div class="min-w-0 flex-1">
				<div class="text-sm font-medium text-red-300">{ title }</div>
				if summary != "" {
					<p class="mt-1 text-xs text-red-200 leading-relaxed break-words">{ summary }</p>
				}
				<div class="relay-action-row mt-2" data-stage-failure-actions>
					{ children... }
				</div>
			</div>
		</div>
	</div>
}


