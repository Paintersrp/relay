package views

import "relay/internal/store"

templ ValidationResultsSummary(run *store.Run, artifacts []store.Artifact, checks []store.Check) {
	if hasValidationRunChecks(checks) {
		<div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 mt-8">
			<h3 class="font-medium mb-3">Validation Command Results</h3>
			<div class="space-y-2">
				for _, c := range checks {
					if c.Kind == "validation_run" {
						<div class="flex items-start gap-2 text-sm py-1">
							if c.Status == "pass" {
								<span class="text-green-400 font-mono shrink-0">PASS</span>
							} else if c.Status == "fail" {
								<span class="text-red-400 font-mono shrink-0">FAIL</span>
							} else {
								<span class="text-yellow-400 font-mono shrink-0">{ c.Status }</span>
							}
							<div class="min-w-0">
								<span class="text-gray-300">{ c.Summary }</span>
								if c.DetailsJson != "" {
									<pre class="mt-1 p-2 bg-gray-950 rounded text-xs font-mono text-gray-400 overflow-x-auto max-h-32 whitespace-pre-wrap">{ c.DetailsJson }</pre>
								}
							</div>
						</div>
					}
				}
			</div>
			if artifactExists(artifacts, "validation_run_json") {
				<div class="mt-3 pt-3 border-t border-gray-800 flex gap-3">
					<a href={"/runs/" + Itoa(run.ID) + "/artifacts/validation_run_json"}
						class="text-xs text-indigo-400 hover:text-indigo-300">View validation JSON</a>
					<a href={"/runs/" + Itoa(run.ID) + "/artifacts/validation_run_json/download"}
						class="text-xs text-gray-500 hover:text-gray-300">Download validation JSON</a>
					if artifactExists(artifacts, "validation_stdout") {
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/validation_stdout"}
							class="text-xs text-indigo-400 hover:text-indigo-300">View stdout</a>
					}
					if artifactExists(artifacts, "validation_stderr") {
						<a href={"/runs/" + Itoa(run.ID) + "/artifacts/validation_stderr"}
							class="text-xs text-indigo-400 hover:text-indigo-300">View stderr</a>
					}
				</div>
			}
		</div>
	}
}

func hasValidationRunChecks(checks []store.Check) bool {
	for _, c := range checks {
		if c.Kind == "validation_run" {
			return true
		}
	}
	return false
}
