package views

templ ArtifactView(content string, kind string) {
	@Layout("Artifact: " + kind) {
		<div class="mb-4 flex items-center justify-between">
			<h1 class="text-xl font-bold">{ kind }</h1>
			<a href="javascript:history.back()" class="text-sm text-gray-500 hover:text-gray-300">&larr; Back</a>
		</div>
		<pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-xs font-mono text-gray-300 overflow-x-auto max-h-[70vh] overflow-y-auto whitespace-pre-wrap">{ content }</pre>
	}
}
