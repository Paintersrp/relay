{
  "schema_version": "relay.mcp.operation-family-tools.v1",
  "input_contract": {
    "root": "OpenOperationFamilyContextRequest",
    "property_order": [
      "packet_id",
      "expected_packet_sha256"
    ],
    "additional_properties": false,
    "properties": {
      "packet_id": {
        "$ref": "#/$defs/OpaqueID"
      },
      "expected_packet_sha256": {
        "$ref": "#/$defs/SHA256"
      }
    }
  },
  "output_contract": {
    "root": "OpenOperationFamilyContextResult",
    "property_order": [
      "route_path",
      "role",
      "surface_contract",
      "operation_id",
      "manifest_domain",
      "standing_authority",
      "domain_authority",
      "packet",
      "inputs",
      "repositories",
      "readiness",
      "blockers"
    ],
    "additional_properties": false,
    "properties": {
      "route_path": {
        "type": "string",
        "const_from_route": true
      },
      "role": {
        "type": "string",
        "const_from_route": true
      },
      "surface_contract": {
        "type": "string",
        "const_from_route": true
      },
      "operation_id": {
        "type": "string",
        "const_from_tool": true
      },
      "manifest_domain": {
        "type": "string",
        "const_from_operation_or_empty": true
      },
      "standing_authority": {
        "$ref": "#/$defs/StandingAuthorityIdentity"
      },
      "domain_authority": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/DomainAuthorityIdentity"
        }
      },
      "packet": {
        "$ref": "#/$defs/OperationPacketView"
      },
      "inputs": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/OperationInputView"
        }
      },
      "repositories": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/OperationRepositoryView"
        }
      },
      "readiness": {
        "$ref": "#/$defs/PacketReadinessState"
      },
      "blockers": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/Blocker"
        }
      }
    }
  },
  "behavior": [
    "Require the exact active packet identity named by packet_id and expected_packet_sha256.",
    "Require packet role, surface contract, and operation ID to equal the route and tool constants.",
    "Return exact packet input, repository, standing-authority, manifest-domain, readiness, and blocker projections.",
    "Do not create, refresh, close, approve, submit, persist, or mutate an artifact or workflow record."
  ],
