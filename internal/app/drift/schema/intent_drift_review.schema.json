{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intent_drift_review",
  "title": "Intent Drift Review",
  "type": "object",
  "required": [
    "intent_drift_review_id",
    "project_id",
    "plan_attempt_id",
    "intent_thread_id",
    "root_intent_packet_id",
    "reviewed_intent_packet_id",
    "review_packet_hash",
    "provenance",
    "overall_alignment",
    "confidence",
    "findings",
    "recommended_action",
    "approval_gate_status",
    "model_metadata",
    "input_hash",
    "output_hash",
    "created_at"
  ],
  "properties": {
    "intent_drift_review_id": {
      "type": "string",
      "pattern": "^intent-drift-review-[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9][a-z0-9-]*$"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "intent_thread_id": {
      "type": "string",
      "minLength": 1
    },
    "root_intent_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_intent_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "review_packet_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "provenance": {
      "type": "object",
      "required": ["review_source", "submitted_by"],
      "properties": {
        "review_source": {
          "type": "string",
          "enum": ["external", "internal"]
        },
        "submitted_by": {
          "type": "string",
          "minLength": 1
        },
        "source_artifact_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 260,
          "pattern": "^(?!/)(?!.*(^|/)\\.\\.($|/))(?!.*\\\\)[A-Za-z0-9._/@+=:-]+(?:/[A-Za-z0-9._/@+=:-]+)*\\.(md|json|txt)$"
        }
      },
      "additionalProperties": false
    },
    "overall_alignment": {
      "type": "string",
      "enum": ["aligned", "minor_drift", "major_drift", "unclear"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "severity", "summary", "evidence", "suggested_resolution"],
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "suggested_resolution": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "recommended_action": {
      "type": "string",
      "enum": ["approve", "approve_with_acknowledgement", "revise", "void", "manual_review"]
    },
    "approval_gate_status": {
      "type": "string",
      "enum": ["not_required", "ready", "acknowledgement_required", "revision_required", "blocked"]
    },
    "model_metadata": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["model_tier"],
          "properties": {
            "provider": {
              "type": "string",
              "minLength": 1
            },
            "model": {
              "type": "string",
              "minLength": 1
            },
            "model_tier": {
              "type": "string",
              "enum": ["economy", "standard", "high_assurance", "auto_escalate"]
            },
            "temperature": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "input_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "output_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
