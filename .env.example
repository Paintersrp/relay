# Relay local OpenCode adapter setup
# Copy this file to .env.local and adjust values for your machine.

RELAY_OPENCODE_BIN=opencode
RELAY_OPENCODE_AGENT=build

# OpenCode Go model mapping for Relay's friendly model label "DeepSeek V4 Flash".
# Confirm available models with:
#   opencode models
RELAY_OPENCODE_MODEL_DEEPSEEK_V4_FLASH=opencode-go/deepseek-v4-flash

# Optional. Leave empty unless using a specific OpenCode variant.
# RELAY_OPENCODE_VARIANT=
