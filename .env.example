# Relay local environment example
# Copy only the values you need to .env or .env.local and adjust them for your
# machine. Both files are ignored by git. Process environment values take
# precedence over these files.

# Relay HTTP/API server. The default is 8080.
# PORT=8080
# RELAY_WEB_BASE_URL=http://localhost:3000

# Workflow persistence defaults. Uncomment only to move the local store.
# RELAY_WORKFLOW_DB_PATH=data/workflow/relay-workflow.sqlite
# RELAY_WORKFLOW_ARTIFACTS_DIR=data/workflow/artifacts

# Optional HTTP MCP bearer token. When set, /mcp requires Authorization: Bearer.
# A tokenless endpoint is for loopback-only connector proof and must not be exposed.
# RELAY_MCP_AUTH_TOKEN=
# RELAY_MCP_DISABLE_AUTH=false

# OpenCode auth is handled by OpenCode itself:
#   opencode
#   /connect
#   /models
# Relay only needs the binary, agent, and provider/model mapping.
RELAY_OPENCODE_BIN=opencode
RELAY_OPENCODE_AGENT=build
RELAY_OPENCODE_MODEL_DEEPSEEK_V4_FLASH=opencode-go/deepseek-v4-flash
# RELAY_OPENCODE_VARIANT=

# Additional OpenCode mappings may be added for labels supported by Relay.
# RELAY_OPENCODE_MODEL_DEEPSEEK_V4_PRO=opencode-go/deepseek-v4-pro
# RELAY_OPENCODE_MODEL_GLM_5=opencode-go/glm-5
# RELAY_OPENCODE_MODEL_GLM_5_1=opencode-go/glm-5.1
# RELAY_OPENCODE_MODEL_KIMI_K2_5=opencode-go/kimi-k2.5
# RELAY_OPENCODE_MODEL_KIMI_K2_6=opencode-go/kimi-k2.6
# RELAY_OPENCODE_MODEL_MIMO_V2_5=opencode-go/mimo-v2.5
# RELAY_OPENCODE_MODEL_MIMO_V2_5_PRO=opencode-go/mimo-v2.5-pro
# RELAY_OPENCODE_MODEL_MINIMAX_M2_5=opencode-go/minimax-m2.5
# RELAY_OPENCODE_MODEL_MINIMAX_M2_7=opencode-go/minimax-m2.7
# RELAY_OPENCODE_MODEL_MINIMAX_M3=opencode-go/minimax-m3
# RELAY_OPENCODE_MODEL_QWEN3_6_PLUS=opencode-go/qwen3.6-plus
# RELAY_OPENCODE_MODEL_QWEN3_7_MAX=opencode-go/qwen3.7-max
# RELAY_OPENCODE_MODEL_QWEN3_7_PLUS=opencode-go/qwen3.7-plus

# Kiro CLI adapter. Kiro must be installed and authenticated separately.
RELAY_KIRO_BIN=kiro-cli
RELAY_KIRO_DEFAULT_MODEL=auto
RELAY_KIRO_EFFORT=high
RELAY_KIRO_TRUST_TOOLS=fs_read,fs_write,grep
# RELAY_KIRO_REQUIRE_MCP_STARTUP=false
# RELAY_KIRO_AGENT=
# RELAY_KIRO_AGENT_ENGINE=
# KIRO_API_KEY=

# ChatGPT MCP secure local tunnel.
TUNNEL_PROFILE=relay-mcp
TUNNEL_ID=tunnel_REPLACE_ME
CONTROL_PLANE_API_KEY=sk-REPLACE_ME

# The canonical profiles are planner, auditor, and local_operator. Missing or
# invalid values fail closed to planner.
RELAY_MCP_PROFILE=planner

# Default: tunnel-client launches the real stdio MCP server through
# scripts/local/relay-mcp-stdio.mjs and cmd/mcpserver.
TUNNEL_MCP_TRANSPORT=stdio

# tunnel-client local health/admin UI. This is independent of Relay web/API.
TUNNEL_HEALTH_LISTEN_ADDR=127.0.0.1:8082

# Optional when tunnel-client or tunnel-client.exe is already on PATH.
# TUNNEL_CLIENT_PATH=C:\Tools\relay-mcp-tunnel\tunnel-client.exe

# Advanced/development HTTP mode. Start cmd/relay separately. The canonical
# endpoint is /mcp on the normal Relay daemon, which defaults to port 8080.
# TUNNEL_MCP_TRANSPORT=http
# RELAY_MCP_URL=http://127.0.0.1:8080/mcp
