# Relay local environment example
# Copy the values you need from this file to .env or .env.local and adjust
# them for your machine. Both files are ignored by git.
#
# OpenCode auth is handled by OpenCode itself:
#   opencode
#   /connect
#   /models
#
# Relay only needs to know which OpenCode binary/agent/model ID to use.

RELAY_OPENCODE_BIN=opencode
RELAY_OPENCODE_AGENT=build

# Relay model label -> OpenCode provider/model mapping.
#
# Relay's model picker may use human-friendly labels like "DeepSeek V4 Flash".
# OpenCode requires exact provider/model IDs like "opencode-go/deepseek-v4-flash".
# If you select a custom model value that already contains "/", Relay passes it
# through directly and no RELAY_OPENCODE_MODEL_* mapping is needed.

RELAY_OPENCODE_MODEL_DEEPSEEK_V4_FLASH=opencode-go/deepseek-v4-flash

# Additional OpenCode Go mappings you may enable if those labels are added to Relay:
# RELAY_OPENCODE_MODEL_DEEPSEEK_V4_PRO=opencode-go/deepseek-v4-pro
# RELAY_OPENCODE_MODEL_GLM_5=opencode-go/glm-5
# RELAY_OPENCODE_MODEL_GLM_5_1=opencode-go/glm-5.1
# RELAY_OPENCODE_MODEL_KIMI_K2_5=opencode-go/kimi-k2.5
# RELAY_OPENCODE_MODEL_KIMI_K2_6=opencode-go/kimi-k2.6
# RELAY_OPENCODE_MODEL_MIMO_V2_5=opencode-go/mimo-v2.5
# RELAY_OPENCODE_MODEL_MIMO_V2_5_PRO=opencode-go/mimo-v2.5-pro
# RELAY_OPENCODE_MODEL_MINIMAX_M2_5=opencode-go/minimax-m2.5
# RELAY_OPENCODE_MODEL_MINIMAX_M2_7=opencode-go/minimax-m2.7
# RELAY_OPENCODE_MODEL_MINIMAX_M3=opencode-go/minimax-m3
# RELAY_OPENCODE_MODEL_QWEN3_6_PLUS=opencode-go/qwen3.6-plus
# RELAY_OPENCODE_MODEL_QWEN3_7_MAX=opencode-go/qwen3.7-max
# RELAY_OPENCODE_MODEL_QWEN3_7_PLUS=opencode-go/qwen3.7-plus

# Optional. Leave empty unless using a specific OpenCode variant.
# RELAY_OPENCODE_VARIANT=

# Kiro CLI adapter. Kiro must be installed and authenticated on the operator
# machine. The run-selected model wins over RELAY_KIRO_DEFAULT_MODEL.
RELAY_KIRO_BIN=kiro-cli
RELAY_KIRO_DEFAULT_MODEL=auto
RELAY_KIRO_EFFORT=high
RELAY_KIRO_TRUST_TOOLS=fs_read,fs_write,grep
# RELAY_KIRO_REQUIRE_MCP_STARTUP=false
# RELAY_KIRO_AGENT=
# RELAY_KIRO_AGENT_ENGINE=
# Optional only if your local Kiro CLI requires API-key auth for headless use.
# KIRO_API_KEY=

# ChatGPT MCP local tunnel
# Copy this file to .env or .env.local. Both files are ignored by git.

TUNNEL_PROFILE=relay-mcp
TUNNEL_ID=tunnel_REPLACE_ME

# Default: tunnel-client launches Relay's real stdio MCP server through scripts/local/relay-mcp-stdio.mjs.
TUNNEL_MCP_TRANSPORT=stdio

# tunnel-client local health/admin UI. Separate from Relay web/API.
# Relay web/API may use 127.0.0.1:8080; tunnel-client defaults to 8082 to avoid collisions.
TUNNEL_HEALTH_LISTEN_ADDR=127.0.0.1:8082

# Optional if tunnel-client or tunnel-client.exe is already on PATH.
# TUNNEL_CLIENT_PATH=C:\Tools\relay-mcp-tunnel\tunnel-client.exe

# Runtime API key for tunnel-client.
# Put the real value in ignored .env/.env.local or in your shell/process env.
CONTROL_PLANE_API_KEY=sk-REPLACE_ME

# Advanced/dev only: HTTP MCP mode. Requires a separately running Relay HTTP daemon.
# TUNNEL_MCP_TRANSPORT=http
# RELAY_MCP_URL=http://127.0.0.1:8081/mcp
